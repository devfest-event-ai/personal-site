# Turso database — get these from: turso db show <db-name> --url && turso db tokens create <db-name>
TURSO_DATABASE_URL=libsql://your-database-name-your-org.turso.io
TURSO_AUTH_TOKEN=your-auth-token-here

# Better Auth — generate secret: openssl rand -base64 32
BETTER_AUTH_SECRET=your-random-32-char-secret-here
BETTER_AUTH_URL=http://localhost:4321

# Google OAuth — create at: https://console.cloud.google.com > APIs & Services > Credentials
# Authorized redirect URI (dev):  http://localhost:4321/api/auth/callback/google
# Authorized redirect URI (prod): https://your-site.netlify.app/api/auth/callback/google
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxx
                                                                                                                                    
GOOGLE_SERVICE_ACCOUNT_EMAIL=your-sa@project-id.iam.gserviceaccount.com                                                                            
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----                                                       
GOOGLE_DRIVE_FOLDER_ID=1abc...xyz   # (opsional — ID folder tujuan upload) 

# Cloudflare Turnstile — create at: https://dash.cloudflare.com/?to=/:account/turnstile
# Site key is public, secret key must stay server-side
TURNSTILE_SITE_KEY=0x4AAAAAAACkPzGJm3OqM8pz  # example key
TURNSTILE_SECRET_KEY=0x4AAAAAAACkPzGJm3OqM8pz-xxxxxxxxxxxx  # example secret

# Edit src/lib/auth-whitelist.js to set which Google accounts can access /admin

# Google Drive Picker API key — create at: https://console.cloud.google.com > APIs & Services > Credentials > Create API Key
# Enable: Google Drive API + Google Picker API
GOOGLE_PICKER_API_KEY=your-api-key-here
