<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 420" width="800" height="420">
  <rect width="800" height="420" fill="#1a1a2e"/>
  <rect width="800" height="420" fill="url(#grid)" opacity="0.06"/>
  <defs>
    <pattern id="grid" width="32" height="32" patternUnits="userSpaceOnUse">
      <path d="M 32 0 L 0 0 0 32" fill="none" stroke="#ffffff" stroke-width="0.5"/>
    </pattern>
  </defs>
  <!-- Node 1: Gmail Trigger -->
  <rect x="60" y="170" width="140" height="80" rx="8" fill="#1e3a5f" stroke="#3b82f6" stroke-width="1.5"/>
  <rect x="60" y="170" width="140" height="28" rx="8" fill="#3b82f6" opacity="0.8"/>
  <text x="130" y="189" text-anchor="middle" font-family="system-ui" font-size="11" fill="white" font-weight="600">Gmail Trigger</text>
  <text x="130" y="222" text-anchor="middle" font-family="system-ui" font-size="9" fill="#94a3b8">Watch inbox</text>
  <text x="130" y="238" text-anchor="middle" font-family="system-ui" font-size="9" fill="#94a3b8">for attachments</text>
  <!-- Arrow 1 -->
  <line x1="200" y1="210" x2="240" y2="210" stroke="#3b82f6" stroke-width="1.5" marker-end="url(#arrow)"/>
  <defs><marker id="arrow" markerWidth="6" markerHeight="6" refX="3" refY="3" orient="auto"><path d="M0,0 L0,6 L6,3 z" fill="#3b82f6"/></marker></defs>
  <!-- Node 2: HTTP Request -->
  <rect x="240" y="170" width="140" height="80" rx="8" fill="#1e3a5f" stroke="#8b5cf6" stroke-width="1.5"/>
  <rect x="240" y="170" width="140" height="28" rx="8" fill="#8b5cf6" opacity="0.8"/>
  <text x="310" y="189" text-anchor="middle" font-family="system-ui" font-size="11" fill="white" font-weight="600">HTTP Request</text>
  <text x="310" y="222" text-anchor="middle" font-family="system-ui" font-size="9" fill="#94a3b8">Gemini Vision</text>
  <text x="310" y="238" text-anchor="middle" font-family="system-ui" font-size="9" fill="#94a3b8">OCR extraction</text>
  <!-- Arrow 2 -->
  <line x1="380" y1="210" x2="420" y2="210" stroke="#3b82f6" stroke-width="1.5" marker-end="url(#arrow)"/>
  <!-- Node 3: Code Node -->
  <rect x="420" y="170" width="140" height="80" rx="8" fill="#1e3a5f" stroke="#f59e0b" stroke-width="1.5"/>
  <rect x="420" y="170" width="140" height="28" rx="8" fill="#f59e0b" opacity="0.8"/>
  <text x="490" y="189" text-anchor="middle" font-family="system-ui" font-size="11" fill="white" font-weight="600">Code Node</text>
  <text x="490" y="222" text-anchor="middle" font-family="system-ui" font-size="9" fill="#94a3b8">Parse invoice</text>
  <text x="490" y="238" text-anchor="middle" font-family="system-ui" font-size="9" fill="#94a3b8">fields</text>
  <!-- Arrow 3 -->
  <line x1="560" y1="210" x2="600" y2="210" stroke="#3b82f6" stroke-width="1.5" marker-end="url(#arrow)"/>
  <!-- Node 4: Google Sheets -->
  <rect x="600" y="170" width="140" height="80" rx="8" fill="#1e3a5f" stroke="#10b981" stroke-width="1.5"/>
  <rect x="600" y="170" width="140" height="28" rx="8" fill="#10b981" opacity="0.8"/>
  <text x="670" y="189" text-anchor="middle" font-family="system-ui" font-size="11" fill="white" font-weight="600">Google Sheets</text>
  <text x="670" y="222" text-anchor="middle" font-family="system-ui" font-size="9" fill="#94a3b8">Append row</text>
  <text x="670" y="238" text-anchor="middle" font-family="system-ui" font-size="9" fill="#94a3b8">to ledger</text>
  <!-- Label -->
  <text x="400" y="380" text-anchor="middle" font-family="system-ui" font-size="12" fill="#475569">Invoice Tracker — n8n Workflow Canvas</text>
  <text x="400" y="400" text-anchor="middle" font-family="system-ui" font-size="10" fill="#334155">Screenshot placeholder — replace with real canvas export</text>
</svg>
