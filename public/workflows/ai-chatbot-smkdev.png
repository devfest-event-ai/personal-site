<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 800 420" width="800" height="420">
  <rect width="800" height="420" fill="#1a1a2e"/>
  <rect width="800" height="420" fill="url(#grid2)" opacity="0.06"/>
  <defs>
    <pattern id="grid2" width="32" height="32" patternUnits="userSpaceOnUse">
      <path d="M 32 0 L 0 0 0 32" fill="none" stroke="#ffffff" stroke-width="0.5"/>
    </pattern>
    <marker id="arrow2" markerWidth="6" markerHeight="6" refX="3" refY="3" orient="auto"><path d="M0,0 L0,6 L6,3 z" fill="#3b82f6"/></marker>
  </defs>
  <!-- Node 1 -->
  <rect x="30" y="170" width="120" height="80" rx="8" fill="#1e3a5f" stroke="#3b82f6" stroke-width="1.5"/>
  <rect x="30" y="170" width="120" height="28" rx="8" fill="#3b82f6" opacity="0.8"/>
  <text x="90" y="189" text-anchor="middle" font-family="system-ui" font-size="10" fill="white" font-weight="600">Telegram Trigger</text>
  <text x="90" y="222" text-anchor="middle" font-family="system-ui" font-size="9" fill="#94a3b8">Receive student</text>
  <text x="90" y="238" text-anchor="middle" font-family="system-ui" font-size="9" fill="#94a3b8">message</text>
  <line x1="150" y1="210" x2="185" y2="210" stroke="#3b82f6" stroke-width="1.5" marker-end="url(#arrow2)"/>
  <!-- Node 2 -->
  <rect x="185" y="170" width="120" height="80" rx="8" fill="#1e3a5f" stroke="#a855f7" stroke-width="1.5"/>
  <rect x="185" y="170" width="120" height="28" rx="8" fill="#a855f7" opacity="0.8"/>
  <text x="245" y="189" text-anchor="middle" font-family="system-ui" font-size="10" fill="white" font-weight="600">Simple Memory</text>
  <text x="245" y="222" text-anchor="middle" font-family="system-ui" font-size="9" fill="#94a3b8">Load conversation</text>
  <text x="245" y="238" text-anchor="middle" font-family="system-ui" font-size="9" fill="#94a3b8">history</text>
  <line x1="305" y1="210" x2="340" y2="210" stroke="#3b82f6" stroke-width="1.5" marker-end="url(#arrow2)"/>
  <!-- Node 3 -->
  <rect x="340" y="170" width="120" height="80" rx="8" fill="#1e3a5f" stroke="#10b981" stroke-width="1.5"/>
  <rect x="340" y="170" width="120" height="28" rx="8" fill="#10b981" opacity="0.8"/>
  <text x="400" y="189" text-anchor="middle" font-family="system-ui" font-size="10" fill="white" font-weight="600">Gemini Pro LLM</text>
  <text x="400" y="222" text-anchor="middle" font-family="system-ui" font-size="9" fill="#94a3b8">Generate context-</text>
  <text x="400" y="238" text-anchor="middle" font-family="system-ui" font-size="9" fill="#94a3b8">aware response</text>
  <line x1="460" y1="210" x2="495" y2="210" stroke="#3b82f6" stroke-width="1.5" marker-end="url(#arrow2)"/>
  <!-- Node 4 -->
  <rect x="495" y="170" width="120" height="80" rx="8" fill="#1e3a5f" stroke="#a855f7" stroke-width="1.5"/>
  <rect x="495" y="170" width="120" height="28" rx="8" fill="#a855f7" opacity="0.8"/>
  <text x="555" y="189" text-anchor="middle" font-family="system-ui" font-size="10" fill="white" font-weight="600">Simple Memory</text>
  <text x="555" y="222" text-anchor="middle" font-family="system-ui" font-size="9" fill="#94a3b8">Save updated</text>
  <text x="555" y="238" text-anchor="middle" font-family="system-ui" font-size="9" fill="#94a3b8">history</text>
  <line x1="615" y1="210" x2="650" y2="210" stroke="#3b82f6" stroke-width="1.5" marker-end="url(#arrow2)"/>
  <!-- Node 5 -->
  <rect x="650" y="170" width="120" height="80" rx="8" fill="#1e3a5f" stroke="#3b82f6" stroke-width="1.5"/>
  <rect x="650" y="170" width="120" height="28" rx="8" fill="#3b82f6" opacity="0.8"/>
  <text x="710" y="189" text-anchor="middle" font-family="system-ui" font-size="10" fill="white" font-weight="600">Telegram</text>
  <text x="710" y="222" text-anchor="middle" font-family="system-ui" font-size="9" fill="#94a3b8">Send reply to</text>
  <text x="710" y="238" text-anchor="middle" font-family="system-ui" font-size="9" fill="#94a3b8">student</text>
  <text x="400" y="380" text-anchor="middle" font-family="system-ui" font-size="12" fill="#475569">AI Chatbot SMKDEV — n8n Workflow Canvas</text>
  <text x="400" y="400" text-anchor="middle" font-family="system-ui" font-size="10" fill="#334155">Screenshot placeholder — replace with real canvas export</text>
</svg>
