---
// Hero.astro — on-load animations via tw-animate-css (animate-in classes)
// Scroll animations are handled by Layout.astro's IntersectionObserver
---

<section class="relative flex min-h-[calc(100svh-65px)] flex-col items-center justify-center overflow-hidden px-4 py-24 text-center sm:px-6">

  <!-- Subtle grid background -->
  <div
    class="pointer-events-none absolute inset-0 -z-10 opacity-[0.025]"
    style="background-image: linear-gradient(var(--color-foreground) 1px, transparent 1px), linear-gradient(90deg, var(--color-foreground) 1px, transparent 1px); background-size: 48px 48px;"
  ></div>

  <!-- Glow blob -->
  <div
    class="pointer-events-none absolute left-1/2 top-1/3 -z-10 h-[400px] w-[600px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-primary/10 blur-3xl"
  ></div>

  <!-- Availability badge -->
  <div class="animate-in fade-in duration-500 mb-6 inline-flex items-center gap-2 rounded-full border border-primary/20 bg-primary/5 px-4 py-1.5 text-sm font-medium text-primary">
    <span class="relative flex h-2 w-2">
      <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-primary opacity-60"></span>
      <span class="relative inline-flex h-2 w-2 rounded-full bg-primary"></span>
    </span>
    Available for Collaborations
  </div>

  <!-- Headline -->
  <h1 class="animate-in fade-in slide-in-from-top-4 duration-700 mb-4 text-4xl font-bold tracking-tight text-foreground sm:text-5xl lg:text-6xl">
    Hi, I'm{" "}
    <span class="text-primary">Rachmawati Ari Taurisia</span>
  </h1>

  <!-- Typewriter row -->
  <div class="animate-in fade-in duration-700 [animation-delay:250ms] mb-6 flex h-9 items-center justify-center gap-1 text-xl font-semibold text-muted-foreground sm:text-2xl">
    <span id="typewriter" aria-live="polite"></span>
    <span class="typewriter-cursor select-none">|</span>
  </div>

  <!-- Hero statement -->
  <p class="animate-in fade-in slide-in-from-bottom-4 duration-700 [animation-delay:450ms] mx-auto mb-10 max-w-2xl text-base leading-relaxed text-muted-foreground sm:text-lg">
    I help professionals and businesses stop repeating and start automating.
    As an AI &amp; Automation Curriculum Architect, I design intelligent learning
    paths and production-ready n8n workflows that integrate GenAI into daily
    productivity.
  </p>

  <!-- CTA buttons -->
  <div class="animate-in fade-in slide-in-from-bottom-4 duration-700 [animation-delay:650ms] flex flex-col gap-3 sm:flex-row">
    <a
      href="/projects"
      class="group inline-flex items-center justify-center gap-2 rounded-lg bg-primary px-6 py-3 text-sm font-semibold text-primary-foreground shadow-sm transition-all duration-200 hover:-translate-y-0.5 hover:bg-primary/90 hover:shadow-md hover:shadow-primary/20"
    >
      View Blueprints
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-200 group-hover:translate-x-0.5">
        <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
      </svg>
    </a>
    <a
      href="/writing"
      class="inline-flex items-center justify-center rounded-lg border border-border bg-background px-6 py-3 text-sm font-semibold text-foreground transition-all duration-200 hover:-translate-y-0.5 hover:bg-accent hover:shadow-sm"
    >
      Subscribe to My Insights
    </a>
  </div>

  <!-- Scroll hint -->
  <div class="animate-in fade-in duration-1000 [animation-delay:1200ms] absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-1.5 text-muted-foreground/50">
    <span class="text-xs tracking-widest uppercase">Scroll</span>
    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="animate-bounce">
      <path d="m6 9 6 6 6-6"/>
    </svg>
  </div>
</section>

<style>
  .typewriter-cursor {
    animation: blink 1s step-end infinite;
  }

  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }
</style>

<script>
  const STRINGS = [
    "AI & Automation Architect",
    "GenAI Curriculum Specialist",
    "Top Tech Content Creator",
  ];

  let strIndex = 0;
  let charIndex = 0;
  let isDeleting = false;

  function tick() {
    const el = document.getElementById("typewriter");
    if (!el) return;

    const current = STRINGS[strIndex];

    if (isDeleting) {
      charIndex--;
    } else {
      charIndex++;
    }

    el.textContent = current.slice(0, charIndex);

    let delay = isDeleting ? 45 : 75;

    if (!isDeleting && charIndex === current.length) {
      isDeleting = true;
      delay = 2200;
    } else if (isDeleting && charIndex === 0) {
      isDeleting = false;
      strIndex = (strIndex + 1) % STRINGS.length;
      delay = 400;
    }

    setTimeout(tick, delay);
  }

  // Start after initial page animations have settled
  setTimeout(tick, 1000);
</script>
