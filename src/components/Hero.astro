---
// Hero.astro — on-load animations via tw-animate-css (animate-in classes)
// Scroll animations are handled by Layout.astro's IntersectionObserver
---

<section class="relative flex min-h-[calc(100svh-65px)] flex-col items-center justify-center overflow-hidden px-4 py-24 text-center sm:px-6">

  <!-- Subtle grid background — no glow blob -->
  <div
    class="pointer-events-none absolute inset-0 -z-10 opacity-[0.025]"
    style="background-image: linear-gradient(var(--color-foreground) 1px, transparent 1px), linear-gradient(90deg, var(--color-foreground) 1px, transparent 1px); background-size: 64px 64px;"
  ></div>

  <!-- Credential line (specific, not generic) -->
  <p class="animate-in fade-in duration-500 mb-8 text-xs font-semibold uppercase tracking-[0.2em] text-muted-foreground">
    AI & Automation Curriculum Architect · n8n · Workflow Design
  </p>

  <!-- Name — primary, no "Hi, I'm" -->
  <h1 class="animate-in fade-in slide-in-from-top-4 duration-700 mb-4 text-5xl font-bold tracking-tight text-foreground sm:text-6xl lg:text-7xl">
    Rachmawati<br><span class="text-primary">Ari Taurisia</span>
  </h1>

  <!-- Role — static, clean, no typewriter -->
  <p class="animate-in fade-in duration-700 [animation-delay:200ms] mb-8 text-lg font-medium text-muted-foreground sm:text-xl">
    AI &amp; Automation Curriculum Architect
  </p>

  <!-- Description — specific, not buzzword-heavy -->
  <p class="animate-in fade-in slide-in-from-bottom-4 duration-700 [animation-delay:400ms] mx-auto mb-10 max-w-[540px] text-base leading-relaxed text-muted-foreground">
    I build n8n workflows that solve real operational problems and teach professionals
    to automate what they repeat every day.
    Everything here is production-ready — not demos.
  </p>

  <!-- CTA buttons -->
  <div class="animate-in fade-in slide-in-from-bottom-4 duration-700 [animation-delay:600ms] flex flex-col gap-3 sm:flex-row sm:justify-center">
    <a
      href="/projects"
      class="group inline-flex items-center justify-center gap-2 rounded-lg bg-primary px-6 py-3 text-sm font-semibold text-primary-foreground shadow-sm transition-all duration-200 hover:-translate-y-0.5 hover:bg-primary/90 hover:shadow-md hover:shadow-primary/20"
    >
      Browse the workflows
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-200 group-hover:translate-x-0.5">
        <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
      </svg>
    </a>
    <a
      href="/contact"
      class="inline-flex items-center justify-center rounded-lg border border-border bg-background px-6 py-3 text-sm font-semibold text-foreground transition-all duration-200 hover:-translate-y-0.5 hover:bg-accent hover:shadow-sm"
    >
      Work with me
    </a>
  </div>
</section>
