---
// LogoStrip.astro: scroll-triggered stagger via [data-animate]
// Each logo uses an inline SVG placeholder.
// REPLACE: swap the <svg> inside each logo entry with the real brand SVG
// once assets are available in src/assets/logos/

const logos = [
  {
    name: "Google Cloud",
    color: "#4285F4",
    svg: `<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="h-6 w-auto">
      <path d="M12.19 2.5c-3.3 0-6.12 1.95-7.5 4.78l2.62 2.04A5.13 5.13 0 0 1 12.19 5.5c1.36 0 2.59.5 3.54 1.32l2.62-2.62A9.02 9.02 0 0 0 12.19 2.5z" fill="#EA4335"/>
      <path d="M5.5 12c0-.59.06-1.16.19-1.7L3.07 8.26A9.05 9.05 0 0 0 2.5 12c0 1.35.3 2.63.81 3.78l2.62-2.62A5.1 5.1 0 0 1 5.5 12z" fill="#FBBC05"/>
      <path d="M12.19 21.5c2.4 0 4.56-.9 6.21-2.35l-2.62-2.04a5.13 5.13 0 0 1-3.59 1.39 5.13 5.13 0 0 1-4.87-3.48L4.7 17.06A9.02 9.02 0 0 0 12.19 21.5z" fill="#34A853"/>
      <path d="M21.5 12c0-.59-.06-1.17-.16-1.73H12.19v3.28h5.24a4.44 4.44 0 0 1-1.96 2.95l2.62 2.04A9.04 9.04 0 0 0 21.5 12z" fill="#4285F4"/>
    </svg>`,
  },
  {
    name: "WomenTech Network",
    color: "#EC4899",
    svg: `<svg viewBox="0 0 112 24" fill="none" xmlns="http://www.w3.org/2000/svg" class="h-6 w-auto">
      <rect width="112" height="24" rx="4" fill="currentColor" class="text-foreground/10"/>
      <text x="8" y="16.5" font-family="system-ui, sans-serif" font-weight="700" font-size="8.5" fill="currentColor" class="text-foreground">WomenTech Network</text>
    </svg>`,
  },
];
---

<section class="border-t border-border bg-muted/30 py-12 px-4 sm:px-6">
  <div class="mx-auto max-w-5xl">

    <!-- Label -->
    <p
      data-animate="fade"
      class="mb-8 text-center text-xs font-semibold uppercase tracking-widest text-muted-foreground"
    >
      Featured In &amp; Collaborated With
    </p>

    <!-- Logo row -->
    <div class="flex flex-wrap items-center justify-center gap-8 sm:gap-12 lg:gap-16">
      {logos.map((logo, i) => (
        <div
          data-animate
          style={`transition-delay: ${120 + i * 120}ms`}
          class="group flex items-center gap-2 grayscale opacity-50 transition-all duration-500 hover:opacity-100 hover:grayscale-0"
          title={logo.name}
        >
          <Fragment set:html={logo.svg} />
        </div>
      ))}
    </div>
  </div>
</section>
