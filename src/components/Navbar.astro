---
const pathname = Astro.url.pathname;

const links = [
  { href: "/", label: "Home" },
  { href: "/projects", label: "Projects" },
  { href: "/writing", label: "Writing" },
  { href: "/speaking", label: "Speaking" },
  { href: "/publications", label: "Publications" },
];

function isActive(href: string) {
  if (href === "/") return pathname === "/";
  return pathname.startsWith(href);
}
---

<header
  id="site-header"
  class="sticky top-0 z-50 w-full border-b border-border/40 bg-background/75 backdrop-blur-xl transition-shadow duration-300"
>
  <nav class="mx-auto flex h-16 max-w-6xl items-center justify-between px-4 sm:px-6">

    <!-- Wordmark -->
    <a href="/" class="group flex items-center gap-1 text-base font-bold tracking-tight text-foreground transition-opacity hover:opacity-80">
      racharta
      <span class="inline-block h-1.5 w-1.5 rounded-full bg-primary transition-transform duration-300 group-hover:scale-125"></span>
    </a>

    <!-- Desktop nav -->
    <ul class="hidden md:flex items-center gap-0.5">
      {links.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              "relative px-3.5 py-2 text-sm transition-colors duration-150 rounded-md",
              isActive(href)
                ? "text-foreground font-semibold"
                : "text-muted-foreground hover:text-foreground",
            ]}
          >
            {label}
            {isActive(href) && (
              <span class="absolute inset-x-3 -bottom-px h-px bg-primary rounded-full" />
            )}
          </a>
        </li>
      ))}
    </ul>

    <!-- Right side: CTA + hamburger -->
    <div class="flex items-center gap-2">
      <!-- Desktop CTA -->
      <a
        href="/contact"
        class="hidden md:inline-flex items-center justify-center rounded-lg bg-primary px-4 py-2 text-sm font-semibold text-primary-foreground transition-all duration-150 hover:-translate-y-px hover:bg-primary/90 hover:shadow-md hover:shadow-primary/20"
      >
        Let's Talk
      </a>

      <!-- Hamburger (mobile) -->
      <button
        id="nav-toggle"
        aria-label="Toggle navigation menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        class="md:hidden rounded-md p-2 text-muted-foreground hover:text-foreground hover:bg-accent transition-colors"
      >
        <!-- Icon: open -->
        <svg id="icon-open" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="4" y1="6" x2="20" y2="6" /><line x1="4" y1="12" x2="20" y2="12" /><line x1="4" y1="18" x2="20" y2="18" />
        </svg>
        <!-- Icon: close -->
        <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden">
          <line x1="18" y1="6" x2="6" y2="18" /><line x1="6" y1="6" x2="18" y2="18" />
        </svg>
      </button>
    </div>
  </nav>

  <!-- Mobile menu -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-t border-border/40 bg-background/95 px-4 pb-5"
  >
    <ul class="flex flex-col gap-0.5 pt-3">
      {links.map(({ href, label }) => (
        <li>
          <a
            href={href}
            class:list={[
              "flex items-center gap-2 rounded-md px-3 py-2.5 text-sm font-medium transition-colors",
              isActive(href)
                ? "bg-primary/10 text-primary font-semibold"
                : "text-muted-foreground hover:text-foreground hover:bg-accent",
            ]}
          >
            {label}
          </a>
        </li>
      ))}
      <li class="pt-2">
        <a
          href="/contact"
          class="flex w-full items-center justify-center rounded-lg bg-primary px-4 py-2.5 text-sm font-semibold text-primary-foreground"
        >
          Let's Talk
        </a>
      </li>
    </ul>
  </div>
</header>

<script>
  // Hamburger toggle
  const toggle = document.getElementById("nav-toggle");
  const menu   = document.getElementById("mobile-menu");
  const iconOpen  = document.getElementById("icon-open");
  const iconClose = document.getElementById("icon-close");

  toggle?.addEventListener("click", () => {
    const isOpen = !menu?.classList.contains("hidden");
    menu?.classList.toggle("hidden", isOpen);
    iconOpen?.classList.toggle("hidden", !isOpen);
    iconClose?.classList.toggle("hidden", isOpen);
    toggle.setAttribute("aria-expanded", String(!isOpen));
  });

  // Elevated shadow when scrolled
  const header = document.getElementById("site-header");
  const onScroll = () => {
    if (window.scrollY > 8) {
      header?.classList.add("shadow-sm");
    } else {
      header?.classList.remove("shadow-sm");
    }
  };
  window.addEventListener("scroll", onScroll, { passive: true });
</script>
