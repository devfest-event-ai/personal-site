---
interface BreadcrumbItem {
  label: string;
  href: string;
}

interface Props {
  items: BreadcrumbItem[];
}

const { items } = Astro.props;
---

<nav aria-label="Breadcrumb" class="mb-8">
  <ol class="flex flex-wrap items-center gap-2 text-sm text-muted-foreground">
    {items.map((item, i) => (
      <li class="flex items-center gap-2">
        {i > 0 && (
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted-foreground/40">
            <path d="m9 18 6-6-6-6"/>
          </svg>
        )}
        <a
          href={item.href}
          class:list={[
            "transition-colors hover:text-foreground",
            i === items.length - 1 ? "text-foreground font-medium" : ""
          ]}
          aria-current={i === items.length - 1 ? "page" : undefined}
        >
          {item.label}
        </a>
      </li>
    ))}
  </ol>
</nav>
