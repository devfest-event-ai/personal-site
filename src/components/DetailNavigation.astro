---
interface NavItem {
  title: string;
  slug: string;
}

interface Props {
  backLabel: string;
  backHref: string;
  prevItem?: NavItem;
  nextItem?: NavItem;
}

const { backLabel, backHref, prevItem, nextItem } = Astro.props;
---

<nav class="mt-16 flex items-center justify-between border-t border-border/40 pt-8">
  <!-- Back link -->
  <a
    href={backHref}
    class="inline-flex items-center gap-1.5 text-sm font-semibold text-primary transition-all duration-200 hover:gap-2.5"
  >
    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
      <path d="m15 18-6-6 6-6"/>
    </svg>
    {backLabel}
  </a>

  <!-- Prev/Next links -->
  <div class="flex items-center gap-6">
    {prevItem && (
      <a
        href={prevItem.slug}
        class="hidden sm:inline-flex items-center gap-1.5 text-sm text-muted-foreground transition-colors hover:text-foreground"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m15 18-6-6 6-6"/>
        </svg>
        <span class="max-w-[200px] truncate">{prevItem.title}</span>
      </a>
    )}
    {nextItem && (
      <a
        href={nextItem.slug}
        class="hidden sm:inline-flex items-center gap-1.5 text-sm text-muted-foreground transition-colors hover:text-foreground"
      >
        <span class="max-w-[200px] truncate">{nextItem.title}</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <path d="m9 18 6-6-6-6"/>
        </svg>
      </a>
    )}
  </div>
</nav>
