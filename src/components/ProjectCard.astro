---
import BlueprintViewer from "@/components/BlueprintViewer.astro";

interface Project {
  id: number;
  title: string;
  slug: string;
  description: string;
  stack: string;
  screenshot_url: string;
  blueprint_snippet: string;
}

interface Props {
  project: Project;
  index: number;
}

const { project, index } = Astro.props;

let stackTags: string[] = [];
try {
  stackTags = JSON.parse(project.stack);
} catch {
  stackTags = [project.stack];
}

const staggerDelay = index * 80;
const hasScreenshot = Boolean(
  project.screenshot_url?.trim() && project.screenshot_url !== "null",
);

// Strip HTML tags and truncate for card preview
const plainDescription = project.description
  .replace(/<[^>]*>/g, " ")
  .replace(/\s+/g, " ")
  .trim();
const shortDescription =
  plainDescription.length > 160
    ? `${plainDescription.slice(0, 160).trimEnd()}…`
    : plainDescription;

const imgName = `proj-img-${project.slug}`;
const titleName = `proj-title-${project.slug}`;
const stackName = `proj-stack-${project.slug}`;
---

<article
  data-animate
  style={`transition-delay: ${staggerDelay}ms`}
  class="group flex flex-col overflow-hidden rounded-2xl border border-border/50 bg-card shadow-sm transition-shadow duration-300 hover:shadow-lg hover:shadow-primary/5"
>
  <!-- Screenshot / Skeleton / Placeholder -->
  <a href={`/projects/${project.slug}`} class="relative block aspect-[16/9] overflow-hidden bg-muted">

    {hasScreenshot ? (
      <>
        <!-- Shimmer skeleton — hidden once image loads -->
        <div
          class="img-skeleton pointer-events-none absolute inset-0 z-10 animate-pulse bg-gradient-to-r from-muted via-border/40 to-muted bg-[length:200%_100%]"
          aria-hidden="true"
        ></div>

        <img
          transition:name={imgName}
          src={project.screenshot_url}
          alt={`${project.title} workflow canvas`}
          loading="lazy"
          decoding="async"
          width="800"
          height="450"
          class="relative z-20 h-full w-full object-cover opacity-0 transition-all duration-500 group-hover:scale-[1.02]"
          onload="this.classList.add('opacity-100'); this.previousElementSibling?.classList.add('hidden')"
          onerror="this.classList.add('hidden'); this.previousElementSibling?.classList.add('hidden'); this.closest('.relative').querySelector('.img-placeholder')?.classList.remove('hidden')"
        />

        <!-- Error fallback placeholder (hidden by default) -->
        <div class="img-placeholder absolute inset-0 z-30 hidden">
          <div class="flex h-full flex-col items-center justify-center gap-3 bg-muted/80 px-4 text-center">
            <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-muted-foreground/40">
              <rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/><circle cx="15" cy="15" r="1" fill="currentColor"/>
            </svg>
            <span class="text-xs text-muted-foreground/50">Preview not available</span>
          </div>
        </div>
      </>
    ) : (
      <!-- No URL — static placeholder -->
      <div
        transition:name={imgName}
        class="absolute inset-0 flex flex-col items-center justify-center gap-3 bg-muted/60 px-4 text-center"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-muted-foreground/30">
          <rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/><circle cx="15" cy="15" r="1" fill="currentColor"/>
        </svg>
        <span class="text-xs text-muted-foreground/40">Workflow preview</span>
      </div>
    )}

  </a>

  <!-- Content -->
  <div class="flex flex-1 flex-col gap-4 p-6">
    <!-- Title (clickable) — shared element transition with detail page -->
    <a
      href={`/projects/${project.slug}`}
      transition:name={titleName}
      class="text-xl font-bold tracking-tight text-foreground transition-colors group-hover:text-primary"
    >
      {project.title}
    </a>

    <!-- Description -->
    <p class="flex-1 text-sm leading-relaxed text-muted-foreground line-clamp-3">
      {shortDescription}
    </p>

    <!-- Stack badges — shared element transition with detail page -->
    <div transition:name={stackName} class="flex flex-wrap gap-1.5">
      {stackTags.map((tag) => (
        <span class="inline-flex items-center rounded-md border border-border/50 bg-muted/60 px-2.5 py-0.5 text-xs font-medium text-muted-foreground">
          {tag}
        </span>
      ))}
    </div>

    <!-- Workflow viewer link (goes to detail page) -->
    <BlueprintViewer projectSlug={project.slug} />
  </div>
</article>
