---
interface Props {
  name: string;
  label: string;
  value?: string;
  required?: boolean;
  id?: string;
  rows?: number;
}
const {
  name,
  label,
  value = "",
  required = false,
  id = name,
  rows = 5,
} = Astro.props;
const editorId = `re-${id}`;
const textareaId = `rt-${id}`;
const minH = `${rows * 1.6}rem`;
---

<div class="flex flex-col gap-1.5 text-sm">
  <span class="font-medium">
    {label}{required && <span class="text-destructive ml-0.5">*</span>}
  </span>

  <div class="rounded-md border border-border overflow-hidden focus-within:ring-1 focus-within:ring-foreground/30">
    <!-- Toolbar -->
    <div class="flex flex-wrap items-center gap-0.5 bg-muted/50 border-b border-border px-2 py-1.5">
      <button type="button" data-editor={editorId} data-cmd="bold"
        class="re-btn px-2 py-0.5 rounded text-xs font-bold hover:bg-background transition-colors" title="Bold">B</button>
      <button type="button" data-editor={editorId} data-cmd="italic"
        class="re-btn px-2 py-0.5 rounded text-xs italic hover:bg-background transition-colors" title="Italic">I</button>
      <button type="button" data-editor={editorId} data-cmd="underline"
        class="re-btn px-2 py-0.5 rounded text-xs underline hover:bg-background transition-colors" title="Underline">U</button>

      <div class="mx-1 self-stretch w-px bg-border/60"></div>

      <button type="button" data-editor={editorId} data-cmd="insertUnorderedList"
        class="re-btn px-2 py-0.5 rounded text-xs hover:bg-background transition-colors" title="Bullet list">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none"
          stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="8" x2="21" y1="6" y2="6"/><line x1="8" x2="21" y1="12" y2="12"/><line x1="8" x2="21" y1="18" y2="18"/>
          <line x1="3" x2="3.01" y1="6" y2="6"/><line x1="3" x2="3.01" y1="12" y2="12"/><line x1="3" x2="3.01" y1="18" y2="18"/>
        </svg>
      </button>
      <button type="button" data-editor={editorId} data-cmd="insertOrderedList"
        class="re-btn px-2 py-0.5 rounded text-xs hover:bg-background transition-colors" title="Numbered list">
        <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none"
          stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="10" x2="21" y1="6" y2="6"/><line x1="10" x2="21" y1="12" y2="12"/><line x1="10" x2="21" y1="18" y2="18"/>
          <path d="M4 6h1v4"/><path d="M4 10h2"/><path d="M6 18H4c0-1 2-2 2-3s-1-1.5-2-1"/>
        </svg>
      </button>

      <div class="mx-1 self-stretch w-px bg-border/60"></div>

      <button type="button" data-editor={editorId} data-cmd="removeFormat"
        class="re-btn px-2 py-0.5 rounded text-xs text-muted-foreground hover:bg-background transition-colors" title="Clear formatting">
        Clear
      </button>
    </div>

    <!-- Editable area -->
    <div
      id={editorId}
      data-target={textareaId}
      contenteditable="true"
      class="px-3 py-2 text-foreground bg-background focus:outline-none prose prose-sm max-w-none"
      style={`min-height: ${minH}`}
      set:html={value}
    ></div>
  </div>

  <!-- Hidden textarea submitted with form -->
  <textarea id={textareaId} name={name} required={required} class="hidden">{value}</textarea>
</div>

<script>
  document.querySelectorAll<HTMLElement>('[contenteditable][data-target]').forEach((editor) => {
    const textarea = document.getElementById(editor.dataset.target!) as HTMLTextAreaElement | null;
    if (!textarea) return;

    editor.addEventListener('input', () => {
      textarea.value = editor.innerHTML;
    });
  });

  document.querySelectorAll<HTMLButtonElement>('.re-btn[data-cmd]').forEach((btn) => {
    btn.addEventListener('mousedown', (e) => {
      e.preventDefault();
      const editor = document.getElementById(btn.dataset.editor!) as HTMLElement | null;
      if (!editor) return;
      document.execCommand(btn.dataset.cmd!, false);
      const textarea = document.getElementById(editor.dataset.target!) as HTMLTextAreaElement | null;
      if (textarea) textarea.value = editor.innerHTML;
    });
  });
</script>
