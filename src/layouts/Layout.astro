---
import "@/styles/starwind.css";
import { SEO } from "astro-seo";
import Navbar from "@/components/Navbar.astro";
import { ClientRouter } from "astro:transitions";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Rachmawati Ari Taurisia — AI & Automation Curriculum Architect",
  description = "AI & Automation Curriculum Engineer and n8n Specialist. I design production-ready workflow automations and GenAI-powered curricula for professionals and businesses in Indonesia.",
} = Astro.props;

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Rachmawati Ari Taurisia",
  jobTitle: "AI & Automation Curriculum Architect",
  url: "https://racharta.vercel.app",
  sameAs: ["https://www.linkedin.com/in/racharta"],
  knowsAbout: [
    "n8n Workflow Automation",
    "GenAI Productivity",
    "Curriculum Design",
    "AI Agent Development",
    "Gemini API",
    "Google Workspace Automation",
  ],
  description: description,
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />

    <!-- Preconnect to critical origins -->
    <link rel="preconnect" href="https://fonts.googleapis.com" crossorigin />
    <link rel="dns-prefetch" href="https://aritaurisia.netlify.app" />

    <SEO
      title={title}
      description={description}
      openGraph={{
        basic: {
          title,
          type: "website",
          image: "/og-image.png",
        },
      }}
      extend={{
        meta: [
          { name: "keywords", content: "AI Automation Curriculum Engineer, n8n Specialist, GenAI Productivity Expert, Workflow Automation Indonesia, Curriculum Designer AI" },
          { name: "author", content: "Rachmawati Ari Taurisia" },
        ],
      }}
    />

    <!-- JSON-LD: Person schema -->
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />

    <ClientRouter />

    <style is:global>
      /* ── View Transition keyframes ─────────────────────────────────────────── */
      @keyframes vt-out {
        to { opacity: 0; }
      }
      @keyframes vt-in {
        from { opacity: 0; }
        to { opacity: 1; }
      }
      @keyframes vt-up {
        from { opacity: 0; transform: translateY(14px); }
        to { opacity: 1; transform: none; }
      }
      @keyframes vt-down {
        from { opacity: 0; transform: translateY(-10px); }
        to { opacity: 1; transform: none; }
      }
    </style>
  </head>
  <body>
    <Navbar />
    <slot />
    <footer class="bg-muted dark:bg-card border-t border-border">
      <div class="max-w-7xl mx-auto px-6 py-12">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <!-- Brand -->
          <div>
            <h3 class="text-lg font-semibold text-foreground mb-3">Rachmawati Ari Taurisia</h3>
            <p class="text-sm text-muted-foreground">AI & Automation Curriculum Architect</p>
            <p class="text-sm text-muted-foreground mt-2">Designing production-ready workflow automations and GenAI-powered curricula for professionals and businesses in Indonesia.</p>
          </div>

          <!-- Quick Links -->
          <div>
            <h4 class="text-sm font-semibold text-foreground mb-3 uppercase tracking-wide">Quick Links</h4>
            <ul class="space-y-2">
              <li><a href="/" class="text-sm text-muted-foreground hover:text-primary transition-colors">Home</a></li>
              <li><a href="/#about" class="text-sm text-muted-foreground hover:text-primary transition-colors">About</a></li>
              <li><a href="/#projects" class="text-sm text-muted-foreground hover:text-primary transition-colors">Projects</a></li>
              <li><a href="/#contact" class="text-sm text-muted-foreground hover:text-primary transition-colors">Contact</a></li>
            </ul>
          </div>

          <!-- Connect -->
          <div>
            <h4 class="text-sm font-semibold text-foreground mb-3 uppercase tracking-wide">Connect</h4>
            <ul class="space-y-2">
              <li><a href="https://www.linkedin.com/in/racharta" target="_blank" rel="noopener noreferrer" class="text-sm text-muted-foreground hover:text-primary transition-colors">LinkedIn</a></li>
              <li><a href="https://racharta.vercel.app" target="_blank" rel="noopener noreferrer" class="text-sm text-muted-foreground hover:text-primary transition-colors">Website</a></li>
              <li><a href="mailto:hello@racharta.com" class="text-sm text-muted-foreground hover:text-primary transition-colors">Email</a></li>
            </ul>
          </div>
        </div>

        <!-- Copyright -->
        <div class="mt-10 pt-8 border-t border-border text-center">
          <p class="text-sm text-muted-foreground">&copy; 2026 Rachmawati Ari Taurisia. All rights reserved.</p>
        </div>
      </div>
    </footer>

    <script>
      function initScrollAnimations() {
        const els = document.querySelectorAll<HTMLElement>("[data-animate]");
        if (!els.length) return;

        const observer = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                observer.unobserve(entry.target);
              }
            });
          },
          { threshold: 0, rootMargin: "0px 0px 200px 0px" }
        );

        els.forEach((el) => observer.observe(el));
      }

      // astro:page-load fires on initial load AND after every View Transition
      document.addEventListener("astro:page-load", initScrollAnimations);
    </script>
  </body>
</html>
