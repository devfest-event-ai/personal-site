---
import "@/styles/starwind.css";
import { SEO } from "astro-seo";
import Navbar from "@/components/Navbar.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Rachmawati Ari Taurisia — AI & Automation Curriculum Architect",
  description = "AI & Automation Curriculum Engineer and n8n Specialist. I design production-ready workflow automations and GenAI-powered curricula for professionals and businesses in Indonesia.",
} = Astro.props;

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": "Rachmawati Ari Taurisia",
  "jobTitle": "AI & Automation Curriculum Architect",
  "url": "https://racharta.vercel.app",
  "sameAs": [
    "https://www.linkedin.com/in/racharta"
  ],
  "knowsAbout": [
    "n8n Workflow Automation",
    "GenAI Productivity",
    "Curriculum Design",
    "AI Agent Development",
    "Gemini API",
    "Google Workspace Automation"
  ],
  "description": description,
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />

    <SEO
      title={title}
      description={description}
      openGraph={{
        basic: {
          title,
          type: "website",
          image: "/og-image.png",
        },
      }}
      extend={{
        meta: [
          { name: "keywords", content: "AI Automation Curriculum Engineer, n8n Specialist, GenAI Productivity Expert, Workflow Automation Indonesia, Curriculum Designer AI" },
          { name: "author", content: "Rachmawati Ari Taurisia" },
        ],
      }}
    />

    <!-- JSON-LD: Person schema -->
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
  </head>
  <body>
    <Navbar />
    <slot />
    <footer class="bg-neutral-100 dark:bg-neutral-900 border-t border-neutral-200 dark:border-neutral-800">
      <div class="max-w-7xl mx-auto px-6 py-12">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
          <!-- Brand -->
          <div>
            <h3 class="text-lg font-semibold text-neutral-900 dark:text-neutral-50 mb-3">Rachmawati Ari Taurisia</h3>
            <p class="text-sm text-neutral-600 dark:text-neutral-400">AI & Automation Curriculum Architect</p>
            <p class="text-sm text-neutral-500 dark:text-neutral-500 mt-2">Designing production-ready workflow automations and GenAI-powered curricula for professionals and businesses in Indonesia.</p>
          </div>

          <!-- Quick Links -->
          <div>
            <h4 class="text-sm font-semibold text-neutral-900 dark:text-neutral-50 mb-3 uppercase tracking-wide">Quick Links</h4>
            <ul class="space-y-2">
              <li><a href="/" class="text-sm text-neutral-600 dark:text-neutral-400 hover:text-blue-700 dark:hover:text-blue-400 transition-colors">Home</a></li>
              <li><a href="/#about" class="text-sm text-neutral-600 dark:text-neutral-400 hover:text-blue-700 dark:hover:text-blue-400 transition-colors">About</a></li>
              <li><a href="/#projects" class="text-sm text-neutral-600 dark:text-neutral-400 hover:text-blue-700 dark:hover:text-blue-400 transition-colors">Projects</a></li>
              <li><a href="/#contact" class="text-sm text-neutral-600 dark:text-neutral-400 hover:text-blue-700 dark:hover:text-blue-400 transition-colors">Contact</a></li>
            </ul>
          </div>

          <!-- Connect -->
          <div>
            <h4 class="text-sm font-semibold text-neutral-900 dark:text-neutral-50 mb-3 uppercase tracking-wide">Connect</h4>
            <ul class="space-y-2">
              <li><a href="https://www.linkedin.com/in/racharta" target="_blank" rel="noopener noreferrer" class="text-sm text-neutral-600 dark:text-neutral-400 hover:text-blue-700 dark:hover:text-blue-400 transition-colors">LinkedIn</a></li>
              <li><a href="https://racharta.vercel.app" target="_blank" rel="noopener noreferrer" class="text-sm text-neutral-600 dark:text-neutral-400 hover:text-blue-700 dark:hover:text-blue-400 transition-colors">Website</a></li>
              <li><a href="mailto:hello@racharta.com" class="text-sm text-neutral-600 dark:text-neutral-400 hover:text-blue-700 dark:hover:text-blue-400 transition-colors">Email</a></li>
            </ul>
          </div>
        </div>

        <!-- Copyright -->
        <div class="mt-10 pt-8 border-t border-neutral-200 dark:border-neutral-800 text-center">
          <p class="text-sm text-neutral-500 dark:text-neutral-500">&copy; 2026 Rachmawati Ari Taurisia. All rights reserved.</p>
        </div>
      </div>
    </footer>
  </body>

  <script>
    function initScrollAnimations() {
      const els = document.querySelectorAll<HTMLElement>("[data-animate]");
      if (!els.length) return;

      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach((entry) => {
            if (entry.isIntersecting) {
              entry.target.classList.add("is-visible");
              observer.unobserve(entry.target);
            }
          });
        },
        { threshold: 0.1, rootMargin: "0px 0px -48px 0px" }
      );

      els.forEach((el) => observer.observe(el));
    }

    document.addEventListener("DOMContentLoaded", initScrollAnimations);
  </script>
</html>
