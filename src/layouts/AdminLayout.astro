---
import "@/styles/starwind.css";
import { auth } from "@/lib/auth.js";

export const prerender = false;

interface Props {
  title: string;
}

const { title } = Astro.props;

const session = await auth.api
  .getSession({ headers: Astro.request.headers })
  .catch(() => null);

const userName = session?.user?.name ?? session?.user?.email ?? "Admin";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title} — Admin</title>
  </head>
  <body class="bg-background text-foreground min-h-screen flex">

    <!-- Sidebar -->
    <aside class="w-56 shrink-0 border-r border-border bg-card flex flex-col">
      <div class="px-5 py-6 border-b border-border">
        <span class="text-sm font-semibold text-foreground">Admin Panel</span>
      </div>
      <nav class="flex-1 px-3 py-4 flex flex-col gap-1 text-sm">
        <a href="/admin" class="px-3 py-2 rounded-md hover:bg-accent hover:text-accent-foreground transition-colors">Dashboard</a>
        <a href="/admin/projects" class="px-3 py-2 rounded-md hover:bg-accent hover:text-accent-foreground transition-colors">Projects</a>
        <a href="/admin/writing" class="px-3 py-2 rounded-md hover:bg-accent hover:text-accent-foreground transition-colors">Writing</a>
        <a href="/admin/publications" class="px-3 py-2 rounded-md hover:bg-accent hover:text-accent-foreground transition-colors">Publications</a>
        <a href="/admin/speaking" class="px-3 py-2 rounded-md hover:bg-accent hover:text-accent-foreground transition-colors">Speaking</a>
      </nav>
    </aside>

    <!-- Main -->
    <div class="flex-1 flex flex-col min-w-0">
      <header class="h-14 border-b border-border bg-card flex items-center justify-end px-6 gap-4">
        <span class="text-sm text-muted-foreground">{userName}</span>
        <form method="POST" action="/api/auth/sign-out">
          <button type="submit" class="text-sm px-3 py-1.5 rounded-md border border-border hover:bg-accent transition-colors">
            Sign out
          </button>
        </form>
      </header>

      <main class="flex-1 p-8 overflow-auto">
        <slot />
      </main>
    </div>

  </body>
</html>
