---
import AdminLayout from "@/layouts/AdminLayout.astro";
import RichEditor from "@/components/RichEditor.astro";
import { db } from "@/db";
import { publications } from "@/db/schema";
import { eq } from "drizzle-orm";
import { requireAdminSession, validateId } from "@/lib/admin-auth";

function makeSlug(title: string) {
  return title.toLowerCase().replace(/[^a-z0-9]+/g, "-").replace(/^-|-$/g, "");
}

export const prerender = false;

const session = await requireAdminSession(Astro.request.headers);
if (!session) {
  return Astro.redirect("/admin/login");
}

const { id: idParam } = Astro.params;
const id = validateId(idParam);

if (!id) {
  return Astro.redirect("/admin/publications");
}

let error = "";

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const action = form.get("_action");

  if (action === "delete") {
    await db.delete(publications).where(eq(publications.id, id));
    return Astro.redirect("/admin/publications");
  }

  const title          = String(form.get("title") ?? "").trim();
  const journal        = String(form.get("journal") ?? "").trim();
  const published_date = String(form.get("published_date") ?? "").trim();
  const abstract       = String(form.get("abstract") ?? "").trim();
  const doi_url        = String(form.get("doi_url") ?? "").trim();
  const type           = String(form.get("type") ?? "").trim();

  if (!title || !journal || !published_date || !abstract || !type) {
    error = "Semua field wajib diisi (kecuali DOI URL).";
  } else {
    await db.update(publications).set({ title, slug: makeSlug(title), journal, publishedDate: published_date, abstract, doiUrl: doi_url || null, type }).where(eq(publications.id, id));
    return Astro.redirect("/admin/publications");
  }
}

const result = await db.select().from(publications).where(eq(publications.id, id)).limit(1);
if (!result || result.length === 0) return Astro.redirect("/admin/publications");

const p = result[0];
---

<AdminLayout title="Edit Publication">
  <div class="max-w-2xl">
    <div class="flex items-center gap-3 mb-6">
      <a href="/admin/publications" class="text-muted-foreground hover:text-foreground text-sm">← Publications</a>
      <h1 class="text-xl font-semibold">Edit Publication</h1>
    </div>

    {error && (
      <div class="mb-4 rounded-md bg-destructive/10 border border-destructive/30 text-destructive text-sm px-4 py-3">{error}</div>
    )}

    <form method="POST" class="bg-card border border-border rounded-xl p-6 flex flex-col gap-4">
      <label class="flex flex-col gap-1.5 text-sm">
        <span class="font-medium">Title</span>
        <input name="title" type="text" required value={String(p.title)} class="px-3 py-2 rounded-md border border-border bg-background text-foreground focus:outline-none focus:ring-1 focus:ring-foreground/30" />
      </label>
      <label class="flex flex-col gap-1.5 text-sm">
        <span class="font-medium">Journal</span>
        <input name="journal" type="text" required value={String(p.journal)} class="px-3 py-2 rounded-md border border-border bg-background text-foreground focus:outline-none focus:ring-1 focus:ring-foreground/30" />
      </label>
      <label class="flex flex-col gap-1.5 text-sm">
        <span class="font-medium">Type</span>
        <select name="type" required class="px-3 py-2 rounded-md border border-border bg-background text-foreground focus:outline-none focus:ring-1 focus:ring-foreground/30">
          <option value="journal" selected={String(p.type) === "journal"}>Journal</option>
          <option value="citation" selected={String(p.type) === "citation"}>Citation</option>
        </select>
      </label>
      <label class="flex flex-col gap-1.5 text-sm">
        <span class="font-medium">Published Date</span>
        <input name="published_date" type="date" required value={String(p.publishedDate)} class="px-3 py-2 rounded-md border border-border bg-background text-foreground focus:outline-none focus:ring-1 focus:ring-foreground/30" />
      </label>
      <RichEditor name="abstract" label="Abstract" required id="abstract" value={String(p.abstract)} rows={5} />
      <label class="flex flex-col gap-1.5 text-sm">
        <span class="font-medium">DOI URL <span class="text-muted-foreground font-normal">(opsional)</span></span>
        <input name="doi_url" type="url" value={p.doiUrl ? String(p.doiUrl) : ""} class="px-3 py-2 rounded-md border border-border bg-background text-foreground focus:outline-none focus:ring-1 focus:ring-foreground/30" />
      </label>
      <div class="flex gap-3 pt-2">
        <button type="submit" class="inline-flex items-center gap-2 rounded-md bg-blue-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-blue-500 transition-colors">
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M19 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h11l5 5v11a2 2 0 0 1-2 2z"/><polyline points="17 21 17 13 7 13 7 21"/><polyline points="7 3 7 8 15 8"/></svg>
          Save
        </button>
        <a href="/admin/publications" class="inline-flex items-center rounded-md border border-border px-5 py-2.5 text-sm font-medium text-foreground hover:bg-accent transition-colors">Cancel</a>
      </div>
    </form>

    <!-- Danger zone -->
    <div class="mt-6 pt-6 border-t border-border">
      <p class="text-sm text-muted-foreground mb-3">Danger zone</p>
      <form method="POST">
        <input type="hidden" name="_action" value="delete" />
        <button
          type="submit"
          onclick="return confirm('Delete this publication? This cannot be undone.')"
          class="inline-flex items-center gap-2 rounded-md bg-red-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-red-500 transition-colors"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
          Delete publication
        </button>
      </form>
    </div>
  </div>
</AdminLayout>
