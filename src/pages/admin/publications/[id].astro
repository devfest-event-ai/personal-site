---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { db } from "@/db";
import { publications } from "@/db/schema";
import { eq } from "drizzle-orm";
import { requireAdminSession, validateId } from "@/lib/admin-auth";

export const prerender = false;

const session = await requireAdminSession(Astro.request.headers);
if (!session) {
  return Astro.redirect("/admin/login");
}

const { id: idParam } = Astro.params;
const id = validateId(idParam);

if (!id) {
  return Astro.redirect("/admin/publications");
}

let error = "";

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const action = form.get("_action");

  if (action === "delete") {
    await db.delete(publications).where(eq(publications.id, id));
    return Astro.redirect("/admin/publications");
  }

  const title          = String(form.get("title") ?? "").trim();
  const journal        = String(form.get("journal") ?? "").trim();
  const published_date = String(form.get("published_date") ?? "").trim();
  const abstract       = String(form.get("abstract") ?? "").trim();
  const doi_url        = String(form.get("doi_url") ?? "").trim();
  const type           = String(form.get("type") ?? "").trim();

  if (!title || !journal || !published_date || !abstract || !type) {
    error = "Semua field wajib diisi (kecuali DOI URL).";
  } else {
    await db.update(publications).set({ title, journal, publishedDate: published_date, abstract, doiUrl: doi_url || null, type }).where(eq(publications.id, id));
    return Astro.redirect("/admin/publications");
  }
}

const result = await db.select().from(publications).where(eq(publications.id, id)).limit(1);
if (!result || result.length === 0) return Astro.redirect("/admin/publications");

const p = result[0];
---

<AdminLayout title="Edit Publication">
  <div class="max-w-2xl">
    <div class="flex items-center gap-3 mb-6">
      <a href="/admin/publications" class="text-muted-foreground hover:text-foreground text-sm">← Publications</a>
      <h1 class="text-xl font-semibold">Edit Publication</h1>
    </div>

    {error && (
      <div class="mb-4 rounded-md bg-destructive/10 border border-destructive/30 text-destructive text-sm px-4 py-3">{error}</div>
    )}

    <form method="POST" class="bg-card border border-border rounded-xl p-6 flex flex-col gap-4">
      <label class="flex flex-col gap-1.5 text-sm">
        <span class="font-medium">Title</span>
        <input name="title" type="text" required value={String(p.title)} class="px-3 py-2 rounded-md border border-border bg-background text-foreground focus:outline-none focus:ring-1 focus:ring-foreground/30" />
      </label>
      <label class="flex flex-col gap-1.5 text-sm">
        <span class="font-medium">Journal</span>
        <input name="journal" type="text" required value={String(p.journal)} class="px-3 py-2 rounded-md border border-border bg-background text-foreground focus:outline-none focus:ring-1 focus:ring-foreground/30" />
      </label>
      <label class="flex flex-col gap-1.5 text-sm">
        <span class="font-medium">Type</span>
        <select name="type" required class="px-3 py-2 rounded-md border border-border bg-background text-foreground focus:outline-none focus:ring-1 focus:ring-foreground/30">
          <option value="journal" selected={String(p.type) === "journal"}>Journal</option>
          <option value="citation" selected={String(p.type) === "citation"}>Citation</option>
        </select>
      </label>
      <label class="flex flex-col gap-1.5 text-sm">
        <span class="font-medium">Published Date</span>
        <input name="published_date" type="date" required value={String(p.published_date)} class="px-3 py-2 rounded-md border border-border bg-background text-foreground focus:outline-none focus:ring-1 focus:ring-foreground/30" />
      </label>
      <label class="flex flex-col gap-1.5 text-sm">
        <span class="font-medium">Abstract</span>
        <textarea name="abstract" required rows="4" class="px-3 py-2 rounded-md border border-border bg-background text-foreground focus:outline-none focus:ring-1 focus:ring-foreground/30 resize-y">{String(p.abstract)}</textarea>
      </label>
      <label class="flex flex-col gap-1.5 text-sm">
        <span class="font-medium">DOI URL <span class="text-muted-foreground font-normal">(opsional)</span></span>
        <input name="doi_url" type="url" value={p.doi_url ? String(p.doi_url) : ""} class="px-3 py-2 rounded-md border border-border bg-background text-foreground focus:outline-none focus:ring-1 focus:ring-foreground/30" />
      </label>
      <div class="flex gap-3 pt-2">
        <button type="submit" class="px-5 py-2 bg-foreground text-background text-sm rounded-md hover:opacity-90 transition-opacity">Save</button>
        <a href="/admin/publications" class="px-5 py-2 border border-border rounded-md text-sm hover:bg-accent transition-colors">Cancel</a>
      </div>
    </form>

    <form method="POST" class="mt-4">
      <input type="hidden" name="_action" value="delete" />
      <button type="submit" class="text-sm text-destructive hover:underline underline-offset-2"
        onclick="return confirm('Delete this publication?')">Delete publication</button>
    </form>
  </div>
</AdminLayout>
