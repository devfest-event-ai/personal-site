---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { db } from "@/db";
import { publications } from "@/db/schema";
import { desc, eq } from "drizzle-orm";
import { requireAdminSession, validateId } from "@/lib/admin-auth";

export const prerender = false;

// Authentication check
const session = await requireAdminSession(Astro.request.headers);
if (!session) {
  return Astro.redirect("/admin/login");
}

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const id = validateId(form.get("id"));
  if (id) {
    await db.delete(publications).where(eq(publications.id, id));
  }
  return Astro.redirect("/admin/publications");
}

const pubs = await db
  .select({
    id: publications.id,
    title: publications.title,
    journal: publications.journal,
    type: publications.type,
    publishedDate: publications.publishedDate,
  })
  .from(publications)
  .orderBy(desc(publications.publishedDate));
---

<AdminLayout title="Publications">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-xl font-semibold">Publications</h1>
    <a href="/admin/publications/new" class="px-4 py-2 bg-foreground text-background text-sm rounded-md hover:opacity-90 transition-opacity">
      + Add Publication
    </a>
  </div>

  <div class="bg-card border border-border rounded-xl overflow-hidden">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-border text-muted-foreground text-left">
          <th class="px-4 py-3 font-medium">ID</th>
          <th class="px-4 py-3 font-medium">Title</th>
          <th class="px-4 py-3 font-medium">Journal</th>
          <th class="px-4 py-3 font-medium">Type</th>
          <th class="px-4 py-3 font-medium">Date</th>
          <th class="px-4 py-3 font-medium">Actions</th>
        </tr>
      </thead>
      <tbody>
        {pubs.map((p) => (
          <tr class="border-b border-border last:border-0 hover:bg-accent/40 transition-colors">
            <td class="px-4 py-3 text-muted-foreground">{p.id}</td>
            <td class="px-4 py-3 font-medium">{p.title}</td>
            <td class="px-4 py-3 text-muted-foreground">{p.journal}</td>
            <td class="px-4 py-3 text-muted-foreground">{p.type}</td>
            <td class="px-4 py-3 text-muted-foreground">{p.publishedDate}</td>
            <td class="px-4 py-3 flex items-center gap-2">
              <a href={`/admin/publications/${p.id}`} class="text-foreground underline-offset-2 hover:underline">Edit</a>
              <form method="POST">
                <input type="hidden" name="id" value={p.id} />
                <button type="submit" class="text-destructive hover:underline underline-offset-2"
                  onclick="return confirm('Delete this publication?')">Delete</button>
              </form>
            </td>
          </tr>
        ))}
        {pubs.length === 0 && (
          <tr>
            <td colspan="6" class="px-4 py-8 text-center text-muted-foreground">No publications yet.</td>
          </tr>
        )}
      </tbody>
    </table>
  </div>
</AdminLayout>
