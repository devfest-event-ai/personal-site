---
import { desc, eq } from "drizzle-orm";
import { db } from "@/db";
import { publications } from "@/db/schema";
import AdminLayout from "@/layouts/AdminLayout.astro";
import { requireAdminSession, validateId } from "@/lib/admin-auth";

export const prerender = false;

// Authentication check
const session = await requireAdminSession(Astro.request.headers);
if (!session) {
  return Astro.redirect("/admin/login");
}

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const id = validateId(form.get("id"));
  if (id) {
    await db.delete(publications).where(eq(publications.id, id));
  }
  return Astro.redirect("/admin/publications");
}

const pubs = await db
  .select({
    id: publications.id,
    title: publications.title,
    journal: publications.journal,
    type: publications.type,
    publishedDate: publications.publishedDate,
  })
  .from(publications)
  .orderBy(desc(publications.publishedDate));
---

<AdminLayout title="Publications">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-xl font-semibold">Publications</h1>
    <a
      href="/admin/publications/new"
      class="inline-flex items-center gap-2 rounded-md bg-blue-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-blue-500 transition-colors"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      Add Publication
    </a>
  </div>

  <div class="bg-card border border-border rounded-xl overflow-hidden">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-border text-muted-foreground text-left">
          <th class="px-4 py-3 font-medium">ID</th>
          <th class="px-4 py-3 font-medium">Title</th>
          <th class="px-4 py-3 font-medium">Journal</th>
          <th class="px-4 py-3 font-medium">Type</th>
          <th class="px-4 py-3 font-medium">Date</th>
          <th class="px-4 py-3 font-medium">Actions</th>
        </tr>
      </thead>
      <tbody>
        {pubs.map((p) => (
          <tr class="border-b border-border last:border-0 hover:bg-accent/40 transition-colors">
            <td class="px-4 py-3 text-muted-foreground text-xs">{p.id}</td>
            <td class="px-4 py-3 font-medium max-w-52 truncate">{p.title}</td>
            <td class="px-4 py-3 text-muted-foreground text-xs">{p.journal}</td>
            <td class="px-4 py-3">
              <span class={`inline-flex items-center rounded-full px-2 py-0.5 text-xs font-medium ${String(p.type) === 'journal' ? 'bg-violet-500/10 text-violet-700 border border-violet-500/30' : 'bg-sky-500/10 text-sky-700 border border-sky-500/30'}`}>
                {p.type}
              </span>
            </td>
            <td class="px-4 py-3 text-muted-foreground text-xs whitespace-nowrap">{p.publishedDate}</td>
            <td class="px-4 py-3">
              <div class="flex items-center gap-1.5">
                <a
                  href={`/admin/publications/${p.id}`}
                  class="inline-flex items-center gap-1 rounded-md bg-amber-500/10 border border-amber-500/30 px-2.5 py-1.5 text-xs font-semibold text-amber-700 hover:bg-amber-500/20 transition-colors"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.85 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/></svg>
                  Edit
                </a>
                <form method="POST">
                  <input type="hidden" name="id" value={p.id} />
                  <button
                    type="submit"
                    onclick="return confirm('Delete this publication?')"
                    class="inline-flex items-center gap-1 rounded-md bg-red-500/10 border border-red-500/30 px-2.5 py-1.5 text-xs font-semibold text-red-700 hover:bg-red-500/20 transition-colors"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                    Delete
                  </button>
                </form>
              </div>
            </td>
          </tr>
        ))}
        {pubs.length === 0 && (
          <tr>
            <td colspan="6" class="px-4 py-8 text-center text-muted-foreground">No publications yet.</td>
          </tr>
        )}
      </tbody>
    </table>
  </div>
</AdminLayout>
