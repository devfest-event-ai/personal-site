---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { db } from "@/db";
import { speaking } from "@/db/schema";
import { eq } from "drizzle-orm";
import { requireAdminSession, validateId } from "@/lib/admin-auth";

export const prerender = false;

const session = await requireAdminSession(Astro.request.headers);
if (!session) {
  return Astro.redirect("/admin/login");
}

const { id: idParam } = Astro.params;
const id = validateId(idParam);

if (!id) {
  return Astro.redirect("/admin/speaking");
}

let error = "";

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const action = form.get("_action");

  if (action === "delete") {
    await db.delete(speaking).where(eq(speaking.id, id));
    return Astro.redirect("/admin/speaking");
  }

  const title       = String(form.get("title") ?? "").trim();
  const provider    = String(form.get("provider") ?? "").trim();
  const event_date  = String(form.get("event_date") ?? "").trim();
  const role        = String(form.get("role") ?? "").trim();
  const description = String(form.get("description") ?? "").trim();
  const link        = String(form.get("link") ?? "").trim();
  const modules     = String(form.get("modules") ?? "").trim();

  if (!title || !provider || !event_date || !role || !description) {
    error = "Semua field wajib diisi (kecuali link dan modules).";
  } else {
    await db.update(speaking).set({ title, provider, eventDate: event_date, role, description, link: link || null, modules: modules || null }).where(eq(speaking.id, id));
    return Astro.redirect("/admin/speaking");
  }
}

const result = await db.select().from(speaking).where(eq(speaking.id, id)).limit(1);
if (!result || result.length === 0) return Astro.redirect("/admin/speaking");

const e = result[0];
---

<AdminLayout title="Edit Speaking Event">
  <div class="max-w-2xl">
    <div class="flex items-center gap-3 mb-6">
      <a href="/admin/speaking" class="text-muted-foreground hover:text-foreground text-sm">← Speaking</a>
      <h1 class="text-xl font-semibold">Edit Speaking Event</h1>
    </div>

    {error && (
      <div class="mb-4 rounded-md bg-destructive/10 border border-destructive/30 text-destructive text-sm px-4 py-3">{error}</div>
    )}

    <form method="POST" class="bg-card border border-border rounded-xl p-6 flex flex-col gap-4">
      <label class="flex flex-col gap-1.5 text-sm">
        <span class="font-medium">Title</span>
        <input name="title" type="text" required value={String(e.title)} class="px-3 py-2 rounded-md border border-border bg-background text-foreground focus:outline-none focus:ring-1 focus:ring-foreground/30" />
      </label>
      <label class="flex flex-col gap-1.5 text-sm">
        <span class="font-medium">Provider</span>
        <input name="provider" type="text" required value={String(e.provider)} class="px-3 py-2 rounded-md border border-border bg-background text-foreground focus:outline-none focus:ring-1 focus:ring-foreground/30" />
      </label>
      <label class="flex flex-col gap-1.5 text-sm">
        <span class="font-medium">Role</span>
        <input name="role" type="text" required value={String(e.role)} class="px-3 py-2 rounded-md border border-border bg-background text-foreground focus:outline-none focus:ring-1 focus:ring-foreground/30" />
      </label>
      <label class="flex flex-col gap-1.5 text-sm">
        <span class="font-medium">Event Date</span>
        <input name="event_date" type="date" required value={String(e.event_date)} class="px-3 py-2 rounded-md border border-border bg-background text-foreground focus:outline-none focus:ring-1 focus:ring-foreground/30" />
      </label>
      <label class="flex flex-col gap-1.5 text-sm">
        <span class="font-medium">Description</span>
        <textarea name="description" required rows="3" class="px-3 py-2 rounded-md border border-border bg-background text-foreground focus:outline-none focus:ring-1 focus:ring-foreground/30 resize-y">{String(e.description)}</textarea>
      </label>
      <label class="flex flex-col gap-1.5 text-sm">
        <span class="font-medium">Link <span class="text-muted-foreground font-normal">(opsional)</span></span>
        <input name="link" type="url" value={e.link ? String(e.link) : ""} class="px-3 py-2 rounded-md border border-border bg-background text-foreground focus:outline-none focus:ring-1 focus:ring-foreground/30" />
      </label>
      <label class="flex flex-col gap-1.5 text-sm">
        <span class="font-medium">Modules <span class="text-muted-foreground font-normal">(JSON, opsional)</span></span>
        <textarea name="modules" rows="4" class="px-3 py-2 rounded-md border border-border bg-background text-foreground focus:outline-none focus:ring-1 focus:ring-foreground/30 resize-y font-mono text-xs">{e.modules ? String(e.modules) : ""}</textarea>
      </label>
      <div class="flex gap-3 pt-2">
        <button type="submit" class="px-5 py-2 bg-foreground text-background text-sm rounded-md hover:opacity-90 transition-opacity">Save</button>
        <a href="/admin/speaking" class="px-5 py-2 border border-border rounded-md text-sm hover:bg-accent transition-colors">Cancel</a>
      </div>
    </form>

    <form method="POST" class="mt-4">
      <input type="hidden" name="_action" value="delete" />
      <button type="submit" class="text-sm text-destructive hover:underline underline-offset-2"
        onclick="return confirm('Delete this event?')">Delete event</button>
    </form>
  </div>
</AdminLayout>
