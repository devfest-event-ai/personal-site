---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { turso } from "@/lib/turso";

export const prerender = false;

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const id = form.get("id");
  if (id) {
    await turso.execute({ sql: "DELETE FROM speaking WHERE id = ?", args: [id] });
  }
  return Astro.redirect("/admin/speaking");
}

const result = await turso.execute("SELECT * FROM speaking ORDER BY event_date DESC");
const events = result.rows.map((r) => ({
  id:         Number(r.id),
  title:      String(r.title),
  provider:   String(r.provider),
  role:       String(r.role),
  event_date: String(r.event_date),
}));
---

<AdminLayout title="Speaking">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-xl font-semibold">Speaking</h1>
    <a href="/admin/speaking/new" class="px-4 py-2 bg-foreground text-background text-sm rounded-md hover:opacity-90 transition-opacity">
      + Add Event
    </a>
  </div>

  <div class="bg-card border border-border rounded-xl overflow-hidden">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-border text-muted-foreground text-left">
          <th class="px-4 py-3 font-medium">ID</th>
          <th class="px-4 py-3 font-medium">Title</th>
          <th class="px-4 py-3 font-medium">Provider</th>
          <th class="px-4 py-3 font-medium">Role</th>
          <th class="px-4 py-3 font-medium">Date</th>
          <th class="px-4 py-3 font-medium">Actions</th>
        </tr>
      </thead>
      <tbody>
        {events.map((e) => (
          <tr class="border-b border-border last:border-0 hover:bg-accent/40 transition-colors">
            <td class="px-4 py-3 text-muted-foreground">{e.id}</td>
            <td class="px-4 py-3 font-medium">{e.title}</td>
            <td class="px-4 py-3 text-muted-foreground">{e.provider}</td>
            <td class="px-4 py-3 text-muted-foreground">{e.role}</td>
            <td class="px-4 py-3 text-muted-foreground">{e.event_date}</td>
            <td class="px-4 py-3 flex items-center gap-2">
              <a href={`/admin/speaking/${e.id}`} class="text-foreground underline-offset-2 hover:underline">Edit</a>
              <form method="POST">
                <input type="hidden" name="id" value={e.id} />
                <button type="submit" class="text-destructive hover:underline underline-offset-2"
                  onclick="return confirm('Delete this event?')">Delete</button>
              </form>
            </td>
          </tr>
        ))}
        {events.length === 0 && (
          <tr>
            <td colspan="6" class="px-4 py-8 text-center text-muted-foreground">No events yet.</td>
          </tr>
        )}
      </tbody>
    </table>
  </div>
</AdminLayout>
