---
import AdminLayout from "@/layouts/AdminLayout.astro";
import RichEditor from "@/components/RichEditor.astro";
import { db } from "@/db";
import { projects } from "@/db/schema";
import { requireAdminSession } from "@/lib/admin-auth";

export const prerender = false;

// Authentication check
const session = await requireAdminSession(Astro.request.headers);
if (!session) {
  return Astro.redirect("/admin/login");
}

let error = "";

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const title            = String(form.get("title") ?? "").trim();
  const slug             = String(form.get("slug") ?? "").trim();
  const description      = String(form.get("description") ?? "").trim();
  const json_source      = String(form.get("json_source") ?? "").trim();
  const stackRaw         = String(form.get("stack") ?? "").trim();
  const stack            = JSON.stringify(stackRaw.split(",").map((s) => s.trim()).filter(Boolean));
  const screenshot_url   = String(form.get("screenshot_url") ?? "").trim();
  const blueprint_snippet = String(form.get("blueprint_snippet") ?? "").trim();

  if (!title || !slug || !description || !json_source || !stack || !screenshot_url || !blueprint_snippet) {
    error = "Semua field wajib diisi.";
  } else {
    await db.insert(projects).values({
      title,
      slug,
      description,
      jsonSource: json_source,
      stack,
      screenshotUrl: screenshot_url,
      blueprintSnippet: blueprint_snippet,
    });
    return Astro.redirect("/admin/projects");
  }
}
---

<AdminLayout title="Add Project">
  <div class="max-w-2xl">
    <div class="flex items-center gap-3 mb-6">
      <a href="/admin/projects" class="text-muted-foreground hover:text-foreground text-sm">← Projects</a>
      <h1 class="text-xl font-semibold">Add Project</h1>
    </div>

    {error && (
      <div class="mb-4 rounded-md bg-destructive/10 border border-destructive/30 text-destructive text-sm px-4 py-3">{error}</div>
    )}

    <form method="POST" class="bg-card border border-border rounded-xl p-6 flex flex-col gap-4">
      <label class="flex flex-col gap-1.5 text-sm">
        <span class="font-medium">Title</span>
        <input name="title" type="text" required class="px-3 py-2 rounded-md border border-border bg-background text-foreground focus:outline-none focus:ring-1 focus:ring-foreground/30" />
      </label>
      <label class="flex flex-col gap-1.5 text-sm">
        <span class="font-medium">Slug</span>
        <input name="slug" type="text" required class="px-3 py-2 rounded-md border border-border bg-background text-foreground focus:outline-none focus:ring-1 focus:ring-foreground/30" />
      </label>
      <RichEditor name="description" label="Description" required id="description" rows={4} />
      <label class="flex flex-col gap-1.5 text-sm">
        <span class="font-medium">JSON Source URL</span>
        <input name="json_source" type="text" required class="px-3 py-2 rounded-md border border-border bg-background text-foreground focus:outline-none focus:ring-1 focus:ring-foreground/30" />
      </label>
      <label class="flex flex-col gap-1.5 text-sm">
        <span class="font-medium">Stack</span>
        <input name="stack" type="text" required placeholder="n8n, Gemini Vision, Gmail API" class="px-3 py-2 rounded-md border border-border bg-background text-foreground focus:outline-none focus:ring-1 focus:ring-foreground/30" />
        <span class="text-xs text-muted-foreground">Pisahkan dengan koma, contoh: n8n, Gemini Vision, Gmail API</span>
      </label>
      <label class="flex flex-col gap-1.5 text-sm">
        <span class="font-medium">Screenshot URL</span>
        <input name="screenshot_url" type="text" required class="px-3 py-2 rounded-md border border-border bg-background text-foreground focus:outline-none focus:ring-1 focus:ring-foreground/30" />
      </label>
      <label class="flex flex-col gap-1.5 text-sm">
        <span class="font-medium">Blueprint Snippet</span>
        <textarea name="blueprint_snippet" required rows="4" class="px-3 py-2 rounded-md border border-border bg-background text-foreground focus:outline-none focus:ring-1 focus:ring-foreground/30 resize-y font-mono text-xs"></textarea>
      </label>
      <div class="flex gap-3 pt-2">
        <button type="submit" class="px-5 py-2 bg-foreground text-background text-sm rounded-md hover:opacity-90 transition-opacity">Save</button>
        <a href="/admin/projects" class="px-5 py-2 border border-border rounded-md text-sm hover:bg-accent transition-colors">Cancel</a>
      </div>
    </form>
  </div>
</AdminLayout>
