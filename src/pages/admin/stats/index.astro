---
import { asc, eq } from "drizzle-orm";
import { db } from "@/db";
import { stats } from "@/db/schema";
import AdminLayout from "@/layouts/AdminLayout.astro";
import { requireAdminSession, validateId } from "@/lib/admin-auth";

export const prerender = false;

const session = await requireAdminSession(Astro.request.headers);
if (!session) {
  return Astro.redirect("/admin/login");
}

let error = "";

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const action = String(form.get("_action") ?? "");

  if (action === "delete") {
    const id = validateId(form.get("id"));
    if (id) {
      await db.delete(stats).where(eq(stats.id, id));
    }
    return Astro.redirect("/admin/stats");
  }

  if (action === "add") {
    const value = String(form.get("value") ?? "").trim();
    const label = String(form.get("label") ?? "").trim();
    const sortOrder = Number(form.get("sort_order") ?? 0);
    if (!value || !label) {
      error = "Value dan Label wajib diisi.";
    } else {
      await db.insert(stats).values({ value, label, sortOrder });
      return Astro.redirect("/admin/stats");
    }
  }

  if (action === "update") {
    const id = validateId(form.get("id"));
    const value = String(form.get("value") ?? "").trim();
    const label = String(form.get("label") ?? "").trim();
    const sortOrder = Number(form.get("sort_order") ?? 0);
    if (id && value && label) {
      await db
        .update(stats)
        .set({ value, label, sortOrder })
        .where(eq(stats.id, id));
    }
    return Astro.redirect("/admin/stats");
  }
}

const allStats = await db
  .select()
  .from(stats)
  .orderBy(asc(stats.sortOrder), asc(stats.id));
---

<AdminLayout title="Stats">
  <div class="">
    <div class="flex items-center justify-between mb-6">
      <h1 class="text-xl font-semibold">Home Stats</h1>
      <a href="/admin" class="text-sm text-muted-foreground hover:text-foreground">← Dashboard</a>
    </div>

    <p class="text-sm text-muted-foreground mb-6">
      Angka-angka kredibilitas yang tampil di halaman utama. Value bebas, bisa angka, persen, singkatan (mis. "60%", "2×", "10K+").
    </p>

    <!-- Current stats table -->
    <div class="bg-card border border-border rounded-xl overflow-hidden mb-8">
      <table class="w-full text-sm">
        <thead>
          <tr class="border-b border-border text-muted-foreground text-left">
            <th class="px-4 py-3 font-medium w-16">Order</th>
            <th class="px-4 py-3 font-medium w-32">Value</th>
            <th class="px-4 py-3 font-medium">Label</th>
            <th class="px-4 py-3 font-medium w-36">Actions</th>
          </tr>
        </thead>
        <tbody>
          {allStats.map((stat) => (
            <tr class="border-b border-border last:border-0 group">
              <form method="POST" class="contents">
                <input type="hidden" name="_action" value="update" />
                <input type="hidden" name="id" value={stat.id} />
                <td class="px-4 py-2">
                  <input
                    name="sort_order"
                    type="number"
                    value={stat.sortOrder}
                    class="w-14 px-2 py-1.5 rounded border border-border bg-background text-foreground text-xs focus:outline-none focus:ring-1 focus:ring-foreground/30"
                  />
                </td>
                <td class="px-4 py-2">
                  <input
                    name="value"
                    type="text"
                    value={stat.value}
                    required
                    class="w-full px-2 py-1.5 rounded border border-border bg-background text-foreground text-sm font-bold focus:outline-none focus:ring-1 focus:ring-foreground/30"
                  />
                </td>
                <td class="px-4 py-2">
                  <input
                    name="label"
                    type="text"
                    value={stat.label}
                    required
                    class="w-full px-2 py-1.5 rounded border border-border bg-background text-foreground text-sm focus:outline-none focus:ring-1 focus:ring-foreground/30"
                  />
                </td>
                <td class="px-4 py-2">
                  <div class="flex items-center gap-1.5">
                    <button
                      type="submit"
                      class="inline-flex items-center gap-1 rounded-md bg-amber-500/10 border border-amber-500/30 px-2.5 py-1.5 text-xs font-semibold text-amber-700 hover:bg-amber-500/20 transition-colors"
                    >
                      Save
                    </button>
                  </div>
                </td>
              </form>
              <td class="px-4 py-2">
                <form method="POST">
                  <input type="hidden" name="_action" value="delete" />
                  <input type="hidden" name="id" value={stat.id} />
                  <button
                    type="submit"
                    onclick="return confirm('Hapus stat ini?')"
                    class="inline-flex items-center gap-1 rounded-md bg-red-500/10 border border-red-500/30 px-2.5 py-1.5 text-xs font-semibold text-red-700 hover:bg-red-500/20 transition-colors"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                    Delete
                  </button>
                </form>
              </td>
            </tr>
          ))}
          {allStats.length === 0 && (
            <tr>
              <td colspan="4" class="px-4 py-8 text-center text-muted-foreground text-sm">Belum ada stats. Tambahkan di bawah.</td>
            </tr>
          )}
        </tbody>
      </table>
    </div>

    <!-- Add new stat -->
    <div class="bg-card border border-border rounded-xl p-6">
      <h2 class="text-base font-semibold mb-4">Tambah Stat Baru</h2>

      {error && (
        <div class="mb-4 rounded-md bg-destructive/10 border border-destructive/30 text-destructive text-sm px-4 py-3">{error}</div>
      )}

      <form method="POST" class="flex flex-col gap-4">
        <input type="hidden" name="_action" value="add" />
        <div class="grid grid-cols-[auto_1fr_1fr] gap-3 items-end">
          <label class="flex flex-col gap-1.5 text-sm">
            <span class="font-medium text-muted-foreground">Order</span>
            <input
              name="sort_order"
              type="number"
              value={allStats.length}
              class="w-16 px-3 py-2 rounded-md border border-border bg-background text-foreground focus:outline-none focus:ring-1 focus:ring-foreground/30"
            />
          </label>
          <label class="flex flex-col gap-1.5 text-sm">
            <span class="font-medium">Value</span>
            <input
              name="value"
              type="text"
              required
              placeholder="mis. 10K+, 60%, 2×"
              class="px-3 py-2 rounded-md border border-border bg-background text-foreground focus:outline-none focus:ring-1 focus:ring-foreground/30"
            />
          </label>
          <label class="flex flex-col gap-1.5 text-sm">
            <span class="font-medium">Label</span>
            <input
              name="label"
              type="text"
              required
              placeholder="mis. n8n workflows"
              class="px-3 py-2 rounded-md border border-border bg-background text-foreground focus:outline-none focus:ring-1 focus:ring-foreground/30"
            />
          </label>
        </div>
        <div>
          <button
            type="submit"
            class="inline-flex items-center gap-2 rounded-md bg-blue-600 px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-blue-500 transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
            Tambah Stat
          </button>
        </div>
      </form>
    </div>

    <p class="mt-4 text-xs text-muted-foreground">
      Tip: Jika tabel stats kosong, home page akan menampilkan fallback default (jumlah workflows, dll).
    </p>
  </div>
</AdminLayout>
