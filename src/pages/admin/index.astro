---
import { count } from "drizzle-orm";
import { db } from "@/db";
import {
  contacts,
  projects,
  publications,
  speaking,
  stats,
  writing,
} from "@/db/schema";
import AdminLayout from "@/layouts/AdminLayout.astro";
import { requireAdminSession } from "@/lib/admin-auth";

export const prerender = false;

// Authentication check
const session = await requireAdminSession(Astro.request.headers);
if (!session) {
  return Astro.redirect("/admin/login");
}

const [projectCount, writingCount, pubCount, speakingCount, contactCount, statsCount] =
  await Promise.all([
    db.select({ count: count() }).from(projects),
    db.select({ count: count() }).from(writing),
    db.select({ count: count() }).from(publications),
    db.select({ count: count() }).from(speaking),
    db.select({ count: count() }).from(contacts),
    db.select({ count: count() }).from(stats),
  ]);

const counts = {
  projects: projectCount[0]?.count ?? 0,
  writing: writingCount[0]?.count ?? 0,
  publications: pubCount[0]?.count ?? 0,
  speaking: speakingCount[0]?.count ?? 0,
  contacts: contactCount[0]?.count ?? 0,
  stats: statsCount[0]?.count ?? 0,
};

const cards = [
  { label: "Projects", count: counts.projects, href: "/admin/projects" },
  { label: "Writing", count: counts.writing, href: "/admin/writing" },
  {
    label: "Publications",
    count: counts.publications,
    href: "/admin/publications",
  },
  { label: "Speaking", count: counts.speaking, href: "/admin/speaking" },
  { label: "Contacts", count: counts.contacts, href: "/admin/contacts" },
  { label: "Home Stats", count: counts.stats, href: "/admin/stats" },
];
---

<AdminLayout title="Dashboard">
  <h1 class="text-xl font-semibold mb-6">Dashboard</h1>

  <div class="grid grid-cols-2 gap-4 max-w-2xl">
    {cards.map((c) => (
      <a
        href={c.href}
        class="bg-card border border-border rounded-xl p-6 hover:border-foreground/30 transition-colors group"
      >
        <p class="text-3xl font-bold text-foreground">{c.count}</p>
        <p class="text-sm text-muted-foreground mt-1 group-hover:text-foreground transition-colors">{c.label}</p>
      </a>
    ))}
  </div>
</AdminLayout>
