---
import "@/styles/starwind.css";
import { auth } from "@/lib/auth.js";

export const prerender = false;

const session = await auth.api
  .getSession({ headers: Astro.request.headers })
  .catch(() => null);

if (session) {
  return Astro.redirect("/admin");
}

const error = Astro.url.searchParams.get("error");
const isDev = import.meta.env.DEV;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>Login: Admin</title>
  </head>
  <body class="bg-background text-foreground min-h-screen flex items-center justify-center px-4">

    <div class="w-full max-w-sm bg-card border border-border rounded-xl p-8 flex flex-col gap-6">
      <div>
        <h1 class="text-lg font-semibold text-foreground">Admin Login</h1>
        <p class="text-sm text-muted-foreground mt-1">Sign in with your Google account to continue.</p>
      </div>

      {error === "unauthorized" && (
        <div class="rounded-md bg-destructive/10 border border-destructive/30 text-destructive text-sm px-4 py-3">
          Email tidak diizinkan mengakses admin panel.
        </div>
      )}

      <button
        id="btn-google"
        class="w-full flex items-center justify-center gap-3 px-4 py-2.5 rounded-md border border-border bg-background hover:bg-accent transition-colors text-sm font-medium"
      >
        <svg width="18" height="18" viewBox="0 0 18 18" fill="none" xmlns="http://www.w3.org/2000/svg">
          <path d="M17.64 9.2c0-.637-.057-1.251-.164-1.84H9v3.481h4.844c-.209 1.125-.843 2.078-1.796 2.717v2.258h2.908c1.702-1.567 2.684-3.875 2.684-6.615z" fill="#4285F4"/>
          <path d="M9 18c2.43 0 4.467-.806 5.956-2.18l-2.908-2.259c-.806.54-1.837.86-3.048.86-2.344 0-4.328-1.584-5.036-3.711H.957v2.332C2.438 15.983 5.482 18 9 18z" fill="#34A853"/>
          <path d="M3.964 10.71c-.18-.54-.282-1.117-.282-1.71s.102-1.17.282-1.71V4.958H.957C.347 6.173 0 7.548 0 9s.348 2.827.957 4.042l3.007-2.332z" fill="#FBBC05"/>
          <path d="M9 3.58c1.321 0 2.508.454 3.44 1.345l2.582-2.58C13.463.891 11.426 0 9 0 5.482 0 2.438 2.017.957 4.958L3.964 6.29C4.672 4.163 6.656 3.58 9 3.58z" fill="#EA4335"/>
        </svg>
        Login dengan Google
      </button>

      {isDev && (
        <div class="relative">
          <div class="absolute inset-0 flex items-center">
            <span class="w-full border-t border-border"></span>
          </div>
          <div class="relative flex justify-center text-xs">
            <span class="bg-card px-2 text-muted-foreground">dev only</span>
          </div>
        </div>

        <a
          href="/api/auth/dev-login"
          class="w-full flex items-center justify-center gap-2 px-4 py-2.5 rounded-md border border-dashed border-amber-500/50 bg-amber-500/5 hover:bg-amber-500/10 transition-colors text-sm font-medium text-amber-600 dark:text-amber-400"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <polyline points="16 18 22 12 16 6"></polyline>
            <polyline points="8 6 2 12 8 18"></polyline>
          </svg>
          Login Dev
        </a>
      )}
    </div>

    <script>
      document.getElementById("btn-google")?.addEventListener("click", async () => {
        const res = await fetch("/api/auth/sign-in/social", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ provider: "google", callbackURL: "/admin" }),
        });
        const data = await res.json();
        if (data?.url) {
          window.location.href = data.url;
        }
      });
    </script>

  </body>
</html>
