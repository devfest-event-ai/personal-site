---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { db } from "@/db";
import { writing } from "@/db/schema";
import { desc, eq } from "drizzle-orm";
import { requireAdminSession, validateId } from "@/lib/admin-auth";

export const prerender = false;

// Authentication check
const session = await requireAdminSession(Astro.request.headers);
if (!session) {
  return Astro.redirect("/admin/login");
}

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const id = validateId(form.get("id"));
  if (id) {
    await db.delete(writing).where(eq(writing.id, id));
  }
  return Astro.redirect("/admin/writing");
}

const articles = await db
  .select({
    id: writing.id,
    title: writing.title,
    category: writing.category,
    url: writing.url,
    publishedDate: writing.publishedDate,
  })
  .from(writing)
  .orderBy(desc(writing.publishedDate));
---

<AdminLayout title="Writing">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-xl font-semibold">Writing</h1>
    <a
      href="/admin/writing/new"
      class="inline-flex items-center gap-2 rounded-md bg-blue-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-blue-500 transition-colors"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/></svg>
      Add Article
    </a>
  </div>

  <div class="bg-card border border-border rounded-xl overflow-hidden">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-border text-muted-foreground text-left">
          <th class="px-4 py-3 font-medium">ID</th>
          <th class="px-4 py-3 font-medium">Title</th>
          <th class="px-4 py-3 font-medium">Category</th>
          <th class="px-4 py-3 font-medium">URL</th>
          <th class="px-4 py-3 font-medium">Date</th>
          <th class="px-4 py-3 font-medium">Actions</th>
        </tr>
      </thead>
      <tbody>
        {articles.map((a) => (
          <tr class="border-b border-border last:border-0 hover:bg-accent/40 transition-colors">
            <td class="px-4 py-3 text-muted-foreground text-xs">{a.id}</td>
            <td class="px-4 py-3 font-medium max-w-52 truncate">{a.title}</td>
            <td class="px-4 py-3 text-muted-foreground text-xs">{a.category}</td>
            <td class="px-4 py-3 text-muted-foreground text-xs truncate max-w-40">
              <a href={String(a.url)} target="_blank" class="hover:text-primary transition-colors underline-offset-2 hover:underline">{a.url}</a>
            </td>
            <td class="px-4 py-3 text-muted-foreground text-xs whitespace-nowrap">{a.publishedDate}</td>
            <td class="px-4 py-3">
              <div class="flex items-center gap-1.5">
                <a
                  href={`/admin/writing/${a.id}`}
                  class="inline-flex items-center gap-1 rounded-md bg-amber-500/10 border border-amber-500/30 px-2.5 py-1.5 text-xs font-semibold text-amber-700 hover:bg-amber-500/20 transition-colors"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 3a2.85 2.85 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/></svg>
                  Edit
                </a>
                <a
                  href={String(a.url)}
                  target="_blank"
                  class="inline-flex items-center gap-1 rounded-md bg-sky-500/10 border border-sky-500/30 px-2.5 py-1.5 text-xs font-semibold text-sky-700 hover:bg-sky-500/20 transition-colors"
                >
                  <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M15 3h6v6"/><path d="M10 14 21 3"/><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/></svg>
                  View
                </a>
                <form method="POST">
                  <input type="hidden" name="id" value={a.id} />
                  <button
                    type="submit"
                    onclick="return confirm('Delete this article?')"
                    class="inline-flex items-center gap-1 rounded-md bg-red-500/10 border border-red-500/30 px-2.5 py-1.5 text-xs font-semibold text-red-700 hover:bg-red-500/20 transition-colors"
                  >
                    <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6"/><path d="M14 11v6"/><path d="M9 6V4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v2"/></svg>
                    Delete
                  </button>
                </form>
              </div>
            </td>
          </tr>
        ))}
        {articles.length === 0 && (
          <tr>
            <td colspan="6" class="px-4 py-8 text-center text-muted-foreground">No articles yet.</td>
          </tr>
        )}
      </tbody>
    </table>
  </div>
</AdminLayout>
