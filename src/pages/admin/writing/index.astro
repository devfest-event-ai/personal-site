---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { turso } from "@/lib/turso";

export const prerender = false;

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const id = form.get("id");
  if (id) {
    await turso.execute({ sql: "DELETE FROM writing WHERE id = ?", args: [id] });
  }
  return Astro.redirect("/admin/writing");
}

const result = await turso.execute("SELECT * FROM writing ORDER BY published_date DESC");
const articles = result.rows.map((r) => ({
  id:             Number(r.id),
  title:          String(r.title),
  category:       String(r.category),
  url:            String(r.url),
  published_date: String(r.published_date),
}));
---

<AdminLayout title="Writing">
  <div class="flex items-center justify-between mb-6">
    <h1 class="text-xl font-semibold">Writing</h1>
    <a href="/admin/writing/new" class="px-4 py-2 bg-foreground text-background text-sm rounded-md hover:opacity-90 transition-opacity">
      + Add Article
    </a>
  </div>

  <div class="bg-card border border-border rounded-xl overflow-hidden">
    <table class="w-full text-sm">
      <thead>
        <tr class="border-b border-border text-muted-foreground text-left">
          <th class="px-4 py-3 font-medium">ID</th>
          <th class="px-4 py-3 font-medium">Title</th>
          <th class="px-4 py-3 font-medium">Category</th>
          <th class="px-4 py-3 font-medium">URL</th>
          <th class="px-4 py-3 font-medium">Date</th>
          <th class="px-4 py-3 font-medium">Actions</th>
        </tr>
      </thead>
      <tbody>
        {articles.map((a) => (
          <tr class="border-b border-border last:border-0 hover:bg-accent/40 transition-colors">
            <td class="px-4 py-3 text-muted-foreground">{a.id}</td>
            <td class="px-4 py-3 font-medium">{a.title}</td>
            <td class="px-4 py-3 text-muted-foreground">{a.category}</td>
            <td class="px-4 py-3 text-muted-foreground truncate max-w-40">{a.url}</td>
            <td class="px-4 py-3 text-muted-foreground">{a.published_date}</td>
            <td class="px-4 py-3 flex items-center gap-2">
              <a href={`/admin/writing/${a.id}`} class="text-foreground underline-offset-2 hover:underline">Edit</a>
              <form method="POST">
                <input type="hidden" name="id" value={a.id} />
                <button type="submit" class="text-destructive hover:underline underline-offset-2"
                  onclick="return confirm('Delete this article?')">Delete</button>
              </form>
            </td>
          </tr>
        ))}
        {articles.length === 0 && (
          <tr>
            <td colspan="6" class="px-4 py-8 text-center text-muted-foreground">No articles yet.</td>
          </tr>
        )}
      </tbody>
    </table>
  </div>
</AdminLayout>
