---
import AdminLayout from "@/layouts/AdminLayout.astro";
import { db } from "@/db";
import { writing } from "@/db/schema";
import { eq } from "drizzle-orm";
import { requireAdminSession, validateId } from "@/lib/admin-auth";

export const prerender = false;

const session = await requireAdminSession(Astro.request.headers);
if (!session) {
  return Astro.redirect("/admin/login");
}

const { id: idParam } = Astro.params;
const id = validateId(idParam);

if (!id) {
  return Astro.redirect("/admin/writing");
}

let error = "";

if (Astro.request.method === "POST") {
  const form = await Astro.request.formData();
  const action = form.get("_action");

  if (action === "delete") {
    await db.delete(writing).where(eq(writing.id, id));
    return Astro.redirect("/admin/writing");
  }

  const title          = String(form.get("title") ?? "").trim();
  const category       = String(form.get("category") ?? "").trim();
  const description    = String(form.get("description") ?? "").trim();
  const url            = String(form.get("url") ?? "").trim();
  const published_date = String(form.get("published_date") ?? "").trim();

  if (!title || !category || !description || !url || !published_date) {
    error = "Semua field wajib diisi.";
  } else {
    await db.update(writing).set({ title, category, description, url, publishedDate: published_date }).where(eq(writing.id, id));
    return Astro.redirect("/admin/writing");
  }
}

const result = await db.select().from(writing).where(eq(writing.id, id)).limit(1);
if (!result || result.length === 0) return Astro.redirect("/admin/writing");

const a = result[0];
---

<AdminLayout title="Edit Article">
  <div class="max-w-2xl">
    <div class="flex items-center gap-3 mb-6">
      <a href="/admin/writing" class="text-muted-foreground hover:text-foreground text-sm">← Writing</a>
      <h1 class="text-xl font-semibold">Edit Article</h1>
    </div>

    {error && (
      <div class="mb-4 rounded-md bg-destructive/10 border border-destructive/30 text-destructive text-sm px-4 py-3">{error}</div>
    )}

    <form method="POST" class="bg-card border border-border rounded-xl p-6 flex flex-col gap-4">
      <label class="flex flex-col gap-1.5 text-sm">
        <span class="font-medium">Title</span>
        <input name="title" type="text" required value={String(a.title)} class="px-3 py-2 rounded-md border border-border bg-background text-foreground focus:outline-none focus:ring-1 focus:ring-foreground/30" />
      </label>
      <label class="flex flex-col gap-1.5 text-sm">
        <span class="font-medium">Category</span>
        <input name="category" type="text" required value={String(a.category)} class="px-3 py-2 rounded-md border border-border bg-background text-foreground focus:outline-none focus:ring-1 focus:ring-foreground/30" />
      </label>
      <label class="flex flex-col gap-1.5 text-sm">
        <span class="font-medium">Description</span>
        <textarea name="description" required rows="3" class="px-3 py-2 rounded-md border border-border bg-background text-foreground focus:outline-none focus:ring-1 focus:ring-foreground/30 resize-y">{String(a.description)}</textarea>
      </label>
      <label class="flex flex-col gap-1.5 text-sm">
        <span class="font-medium">URL</span>
        <input name="url" type="url" required value={String(a.url)} class="px-3 py-2 rounded-md border border-border bg-background text-foreground focus:outline-none focus:ring-1 focus:ring-foreground/30" />
      </label>
      <label class="flex flex-col gap-1.5 text-sm">
        <span class="font-medium">Published Date</span>
        <input name="published_date" type="date" required value={String(a.published_date)} class="px-3 py-2 rounded-md border border-border bg-background text-foreground focus:outline-none focus:ring-1 focus:ring-foreground/30" />
      </label>
      <div class="flex gap-3 pt-2">
        <button type="submit" class="px-5 py-2 bg-foreground text-background text-sm rounded-md hover:opacity-90 transition-opacity">Save</button>
        <a href="/admin/writing" class="px-5 py-2 border border-border rounded-md text-sm hover:bg-accent transition-colors">Cancel</a>
      </div>
    </form>

    <form method="POST" class="mt-4">
      <input type="hidden" name="_action" value="delete" />
      <button type="submit" class="text-sm text-destructive hover:underline underline-offset-2"
        onclick="return confirm('Delete this article?')">Delete article</button>
    </form>
  </div>
</AdminLayout>
