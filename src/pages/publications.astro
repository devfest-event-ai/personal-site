---
import Layout from "@/layouts/Layout.astro";
import { turso } from "@/lib/turso";

const result = await turso.execute("SELECT * FROM publications ORDER BY published_date DESC");

const allPubs = result.rows.map((row) => ({
  id:             Number(row.id),
  title:          String(row.title),
  journal:        String(row.journal),
  published_date: String(row.published_date),
  abstract:       String(row.abstract),
  doi_url:        row.doi_url ? String(row.doi_url) : null,
  type:           String(row.type),
}));

const journals   = allPubs.filter((p) => p.type === "journal");
const citations  = allPubs.filter((p) => p.type === "citation");
---

<Layout
  title="Publications — Rachmawati Ari Taurisia"
  description="Academic publications and expert citations by Rachmawati Ari Taurisia — covering AI curriculum design, digital transformation, and workflow automation research."
>
  <main>
    <!-- Page Hero -->
    <section class="relative overflow-hidden border-b border-border/40 bg-background px-4 py-20 text-center sm:px-6">
      <div class="pointer-events-none absolute left-1/2 top-1/2 -z-10 h-[300px] w-[500px] -translate-x-1/2 -translate-y-1/2 rounded-full bg-primary/8 blur-3xl"></div>

      <p class="animate-in fade-in duration-500 mb-4 inline-flex items-center gap-2 rounded-full border border-primary/20 bg-primary/5 px-4 py-1.5 text-sm font-medium text-primary">
        Publications
      </p>

      <h1 class="animate-in fade-in slide-in-from-top-4 duration-700 mb-4 text-4xl font-bold tracking-tight text-foreground sm:text-5xl">
        Research &<br/>
        <span class="text-primary">Expert Citations</span>
      </h1>

      <p class="animate-in fade-in slide-in-from-bottom-4 duration-700 [animation-delay:300ms] mx-auto max-w-2xl text-base leading-relaxed text-muted-foreground sm:text-lg">
        Academic contributions and industry citations on AI curriculum design, digital transformation, and automation.
      </p>

      <div class="animate-in fade-in duration-700 [animation-delay:500ms] mt-6 flex items-center justify-center gap-6 text-sm text-muted-foreground">
        <span class="flex items-center gap-1.5">
          <span class="h-1.5 w-1.5 rounded-full bg-primary"></span>
          {journals.length} journal{journals.length !== 1 ? "s" : ""}
        </span>
        <span class="flex items-center gap-1.5">
          <span class="h-1.5 w-1.5 rounded-full bg-primary/50"></span>
          {citations.length} citation{citations.length !== 1 ? "s" : ""}
        </span>
      </div>
    </section>

    <!-- Journal Publications -->
    {journals.length > 0 && (
      <section class="mx-auto max-w-4xl px-4 py-16 sm:px-6">
        <div class="mb-10">
          <p
            data-animate="fade"
            class="mb-2 text-xs font-semibold uppercase tracking-widest text-primary"
          >
            Journal Publications
          </p>
          <h2
            data-animate
            class="text-2xl font-bold tracking-tight text-foreground sm:text-3xl"
          >
            Peer-Reviewed Work
          </h2>
        </div>

        <div class="flex flex-col gap-6">
          {journals.map((pub, i) => {
            const dateFormatted = new Date(pub.published_date).toLocaleDateString("id-ID", { year: "numeric", month: "long" });
            return (
              <article
                data-animate
                style={`transition-delay: ${100 + i * 120}ms`}
                class="group overflow-hidden rounded-2xl border border-border/50 bg-card p-6 shadow-sm transition-shadow duration-300 hover:shadow-md hover:shadow-primary/5 sm:p-8"
              >
                <!-- Header row -->
                <div class="mb-4 flex flex-wrap items-start gap-3">
                  <span class="inline-flex items-center gap-1.5 rounded-full border border-primary/30 bg-primary/5 px-3 py-1 text-xs font-semibold text-primary">
                    <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/>
                    </svg>
                    Journal Article
                  </span>
                  <time datetime={pub.published_date} class="ml-auto text-xs text-muted-foreground/70 pt-1">
                    {dateFormatted}
                  </time>
                </div>

                <!-- Title -->
                <h3 class="mb-2 text-lg font-bold tracking-tight text-foreground transition-colors group-hover:text-primary sm:text-xl">
                  {pub.title}
                </h3>

                <!-- Journal name -->
                <p class="mb-4 text-xs font-medium text-muted-foreground">
                  {pub.journal}
                </p>

                <!-- Abstract -->
                <p class="text-sm leading-relaxed text-muted-foreground">
                  {pub.abstract}
                </p>

                <!-- DOI link if available -->
                {pub.doi_url && (
                  <a
                    href={pub.doi_url}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="mt-4 inline-flex items-center gap-1.5 text-sm font-medium text-primary transition-all duration-200 hover:gap-2.5"
                  >
                    View paper
                    <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" x2="21" y1="14" y2="3"/>
                    </svg>
                  </a>
                )}
              </article>
            );
          })}
        </div>
      </section>
    )}

    <!-- Citations -->
    {citations.length > 0 && (
      <section class="border-t border-border/40 bg-muted/30">
        <div class="mx-auto max-w-4xl px-4 py-16 sm:px-6">
          <div class="mb-10">
            <p
              data-animate="fade"
              class="mb-2 text-xs font-semibold uppercase tracking-widest text-primary"
            >
              Expert Citations
            </p>
            <h2
              data-animate
              class="text-2xl font-bold tracking-tight text-foreground sm:text-3xl"
            >
              Referenced as SME
            </h2>
            <p
              data-animate
              style="transition-delay: 100ms"
              class="mt-3 max-w-xl text-base text-muted-foreground"
            >
              Cited as subject matter expert in academic and industry research.
            </p>
          </div>

          <div class="flex flex-col gap-4">
            {citations.map((pub, i) => {
              const dateFormatted = new Date(pub.published_date).toLocaleDateString("id-ID", { year: "numeric", month: "long" });
              return (
                <article
                  data-animate
                  style={`transition-delay: ${100 + i * 100}ms`}
                  class="flex flex-col gap-3 rounded-xl border border-border/50 bg-card p-5 shadow-sm transition-shadow duration-200 hover:shadow-md hover:shadow-primary/5 sm:flex-row sm:items-start sm:gap-6 sm:p-6"
                >
                  <!-- Date column -->
                  <div class="shrink-0 sm:w-28">
                    <time datetime={pub.published_date} class="text-xs text-muted-foreground/70">
                      {dateFormatted}
                    </time>
                  </div>

                  <!-- Content -->
                  <div class="flex flex-1 flex-col gap-2">
                    <span class="inline-flex w-fit items-center gap-1.5 rounded-md border border-amber-400/40 bg-amber-400/10 px-2.5 py-0.5 text-xs font-medium text-amber-400">
                      <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M12 20h9"/><path d="M16.5 3.5a2.12 2.12 0 0 1 3 3L7 19l-4 1 1-4Z"/>
                      </svg>
                      Citation
                    </span>
                    <p class="font-semibold text-foreground">{pub.title}</p>
                    <p class="text-xs text-muted-foreground">{pub.journal}</p>
                    <p class="text-sm leading-relaxed text-muted-foreground">{pub.abstract}</p>
                  </div>
                </article>
              );
            })}
          </div>
        </div>
      </section>
    )}

    {allPubs.length === 0 && (
      <div class="py-32 text-center text-muted-foreground">No publications found.</div>
    )}
  </main>
</Layout>
