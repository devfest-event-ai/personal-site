---
import Layout from "@/layouts/Layout.astro";
import ProjectCard from "@/components/ProjectCard.astro";
import { db } from "@/db";
import { projects as projectsTable } from "@/db/schema";
import { asc } from "drizzle-orm";

const result = await db
  .select()
  .from(projectsTable)
  .orderBy(asc(projectsTable.id));

const projects = result.map((row) => ({
  id:                Number(row.id),
  title:             String(row.title),
  slug:              String(row.slug),
  description:       String(row.description),
  json_source:       String(row.jsonSource),
  stack:             String(row.stack),
  screenshot_url:    String(row.screenshotUrl),
  blueprint_snippet: String(row.blueprintSnippet),
}));
---

<Layout
  title="Automation Workflows — Rachmawati Ari Taurisia"
  description="Production-ready n8n workflow automations built for real-world productivity: invoice extraction, AI chatbots, and multi-persona task orchestration."
>
  <main>
    <!-- Page header — left-aligned, no glow, no pill badge -->
    <section class="border-b border-border/40 bg-background px-4 py-16 sm:px-6">
      <div class="mx-auto max-w-6xl">
        <div class="flex flex-col gap-8 lg:flex-row lg:items-end lg:justify-between">
          <div>
            <p class="animate-in fade-in duration-500 mb-3 text-xs font-semibold uppercase tracking-[0.2em] text-muted-foreground">
              Automation Workflows
            </p>
            <h1 class="animate-in fade-in slide-in-from-top-4 duration-700 mb-4 text-4xl font-bold tracking-tight text-foreground sm:text-5xl">
              Production-Ready<br>
              <span class="text-primary">n8n Workflows</span>
            </h1>
            <p class="animate-in fade-in duration-700 [animation-delay:200ms] max-w-xl text-base leading-relaxed text-muted-foreground">
              Real automations built for real problems. Each workflow is fully
              documented with node-by-node structure — no credentials, no fluff.
            </p>
          </div>

          <!-- Inline stats — right side on desktop -->
          <div class="animate-in fade-in duration-700 [animation-delay:300ms] flex shrink-0 items-center gap-8 lg:flex-col lg:items-end lg:gap-3">
            <div class="lg:text-right">
              <p class="text-4xl font-bold tracking-tight text-foreground">{projects.length}</p>
              <p class="text-sm text-muted-foreground">live workflows</p>
            </div>
            <div class="h-8 w-px bg-border lg:hidden"></div>
            <div class="lg:text-right">
              <p class="text-sm font-semibold text-foreground">Structural JSON</p>
              <p class="text-xs text-muted-foreground">included on every card</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Projects grid -->
    <section class="mx-auto max-w-6xl px-4 py-16 sm:px-6">
      {projects.length > 0 ? (
        <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
          {projects.map((project, i) => (
            <ProjectCard project={project} index={i} />
          ))}
        </div>
      ) : (
        <p class="py-20 text-center text-muted-foreground">No workflows found.</p>
      )}
    </section>
  </main>
</Layout>
