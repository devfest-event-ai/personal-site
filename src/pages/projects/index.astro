---
import type { TransitionDirectionalAnimations } from "astro";
import { asc } from "drizzle-orm";
import ProjectCard from "@/components/ProjectCard.astro";
import { db } from "@/db";
import { projects as projectsTable } from "@/db/schema";
import Layout from "@/layouts/Layout.astro";

const result = await db
  .select()
  .from(projectsTable)
  .orderBy(asc(projectsTable.id));

const projects = result.map((row) => ({
  id: Number(row.id),
  title: String(row.title),
  slug: String(row.slug),
  description: String(row.description),
  stack: String(row.stack),
  preview_url: String(row.previewUrl),
}));

const fadeBack = {
  old: {
    name: "vt-out",
    duration: "0.15s",
    easing: "ease-in",
    fillMode: "both",
  },
  new: {
    name: "vt-in",
    duration: "0.2s",
    easing: "ease-out",
    fillMode: "both",
  },
};
const animDown: TransitionDirectionalAnimations = {
  forwards: {
    old: {
      name: "vt-out",
      duration: "0.15s",
      easing: "ease-in",
      fillMode: "both",
    },
    new: {
      name: "vt-down",
      duration: "0.35s",
      easing: "ease-out",
      fillMode: "both",
    },
  },
  backwards: fadeBack,
};
const animUp0: TransitionDirectionalAnimations = {
  forwards: {
    old: {
      name: "vt-out",
      duration: "0.15s",
      easing: "ease-in",
      fillMode: "both",
    },
    new: {
      name: "vt-up",
      duration: "0.45s",
      easing: "ease-out",
      fillMode: "both",
    },
  },
  backwards: fadeBack,
};
---

<Layout
  title="Automation Workflows: Rachmawati Ari Taurisia"
  description="Production-ready n8n workflow automations built for real-world productivity: invoice extraction, AI chatbots, and multi-persona task orchestration."
>
  <main>
    <!-- Page header -->
    <section
      transition:animate={animDown}
      class="border-b border-border/40 bg-background px-4 py-16 sm:px-6"
    >
      <div class="mx-auto max-w-4xl">
        <div class="flex flex-col gap-8 lg:flex-row lg:items-end lg:justify-between">
          <div>
            <p class="mb-3 text-xs font-semibold uppercase tracking-[0.2em] text-muted-foreground">
              Automation Workflows
            </p>
            <h1
              transition:name="projects-heading"
              class="mb-4 text-4xl font-bold tracking-tight text-foreground sm:text-5xl"
            >
              Production-Ready<br>
              <span class="text-primary">n8n Workflows</span>
            </h1>
            <p class="max-w-xl text-base leading-relaxed text-muted-foreground">
              Real automations built for real problems. Each workflow is fully
              documented with node-by-node structure and no credentials, no fluff.
            </p>
          </div>

          <!-- Inline stats: right side on desktop -->
          <div class="flex shrink-0 items-center gap-8 lg:flex-col lg:items-end lg:gap-3">
            <div class="lg:text-right">
              <p class="text-4xl font-bold tracking-tight text-foreground">{projects.length}</p>
              <p class="text-sm text-muted-foreground">live workflows</p>
            </div>
            <div class="h-8 w-px bg-border lg:hidden"></div>
            <div class="lg:text-right">
              <p class="text-sm font-semibold text-foreground">Structural JSON</p>
              <p class="text-xs text-muted-foreground">included on every card</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Projects grid -->
    <section
      transition:animate={animUp0}
      class="mx-auto max-w-4xl px-4 py-16 sm:px-6"
    >
      {projects.length > 0 ? (
        <div class="grid gap-8 sm:grid-cols-2 lg:grid-cols-3">
          {projects.map((project, i) => (
            <ProjectCard project={project} index={i} />
          ))}
        </div>
      ) : (
        <p class="py-20 text-center text-muted-foreground">No workflows found.</p>
      )}
    </section>
  </main>
</Layout>
