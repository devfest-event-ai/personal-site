---
export const prerender = false;

import type { TransitionDirectionalAnimations } from "astro";
import { asc, eq } from "drizzle-orm";
import Breadcrumb from "@/components/Breadcrumb.astro";
import DetailNavigation from "@/components/DetailNavigation.astro";
import { db } from "@/db";
import { projects } from "@/db/schema";
import Layout from "@/layouts/Layout.astro";

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect("/404");
}

const result = await db
  .select()
  .from(projects)
  .where(eq(projects.slug, slug))
  .limit(1);

if (result.length === 0) {
  return Astro.redirect("/404");
}

const project = result[0];
const projectId = Number(project.id);
const title = String(project.title);
const description = String(project.description);
const previewUrl = String(project.previewUrl);
const stack = String(project.stack);

let stackTags: string[] = [];
try {
  stackTags = JSON.parse(stack);
} catch {
  stackTags = [stack];
}

function isYouTubeUrl(url: string): boolean {
  return /(?:youtube\.com\/(?:watch\?v=|embed\/)|youtu\.be\/)/i.test(url);
}

function getYouTubeEmbedUrl(url: string): string {
  const match = url.match(
    /(?:youtube\.com\/watch\?v=|youtu\.be\/)([a-zA-Z0-9_-]{11})/,
  );
  return match ? `https://www.youtube.com/embed/${match[1]}` : "";
}

function convertDriveLink(url: string): string {
  const match = url.match(/\/file\/d\/([^/]+)/);
  if (match)
    return `https://drive.google.com/thumbnail?id=${match[1]}&sz=w1200`;
  return url;
}

const isYouTube = isYouTubeUrl(previewUrl);
const hasPreview = Boolean(previewUrl?.trim() && previewUrl !== "null");
const displayImageUrl = isYouTube ? "" : convertDriveLink(previewUrl);

// Get prev/next projects
const allProjects = await db
  .select({ id: projects.id, title: projects.title, slug: projects.slug })
  .from(projects)
  .orderBy(asc(projects.id));
const projectsList = allProjects.map((row) => ({
  id: Number(row.id),
  title: String(row.title),
  slug: String(row.slug),
}));

const currentIndex = projectsList.findIndex((p) => p.slug === slug);
const prevProject = currentIndex > 0 ? projectsList[currentIndex - 1] : null;
const nextProject =
  currentIndex < projectsList.length - 1
    ? projectsList[currentIndex + 1]
    : null;

// Shared transition names: must match ProjectCard.astro
const imgName = `proj-img-${slug}`;
const titleName = `proj-title-${slug}`;
const stackName = `proj-stack-${slug}`;

// Per-element enter animations (staggered with delay)
// transition:animate requires TransitionDirectionalAnimations (not TransitionAnimationPair directly)
const fadeBack = {
  old: {
    name: "vt-out",
    duration: "0.15s",
    easing: "ease-in",
    fillMode: "both",
  },
  new: {
    name: "vt-in",
    duration: "0.2s",
    easing: "ease-out",
    fillMode: "both",
  },
};
const animDown: TransitionDirectionalAnimations = {
  forwards: {
    old: {
      name: "vt-out",
      duration: "0.15s",
      easing: "ease-in",
      fillMode: "both",
    },
    new: {
      name: "vt-down",
      duration: "0.35s",
      easing: "ease-out",
      fillMode: "both",
    },
  },
  backwards: fadeBack,
};
const animUp0: TransitionDirectionalAnimations = {
  forwards: {
    old: {
      name: "vt-out",
      duration: "0.15s",
      easing: "ease-in",
      fillMode: "both",
    },
    new: {
      name: "vt-up",
      duration: "0.4s",
      easing: "ease-out",
      fillMode: "both",
    },
  },
  backwards: fadeBack,
};
const animUp1: TransitionDirectionalAnimations = {
  forwards: {
    old: {
      name: "vt-out",
      duration: "0.15s",
      easing: "ease-in",
      fillMode: "both",
    },
    new: {
      name: "vt-up",
      duration: "0.4s",
      delay: "0.07s",
      easing: "ease-out",
      fillMode: "both",
    },
  },
  backwards: fadeBack,
};
const animUp2: TransitionDirectionalAnimations = {
  forwards: {
    old: {
      name: "vt-out",
      duration: "0.15s",
      easing: "ease-in",
      fillMode: "both",
    },
    new: {
      name: "vt-up",
      duration: "0.4s",
      delay: "0.14s",
      easing: "ease-out",
      fillMode: "both",
    },
  },
  backwards: fadeBack,
};
const animUp3: TransitionDirectionalAnimations = {
  forwards: {
    old: {
      name: "vt-out",
      duration: "0.15s",
      easing: "ease-in",
      fillMode: "both",
    },
    new: {
      name: "vt-up",
      duration: "0.4s",
      delay: "0.21s",
      easing: "ease-out",
      fillMode: "both",
    },
  },
  backwards: fadeBack,
};

const plainDescription = description
  .replace(/<[^>]*>/g, " ")
  .replace(/\s+/g, " ")
  .trim();
const seo = {
  title: `${title}: Rachmawati Ari Taurisia`,
  description: plainDescription.substring(0, 160),
};
---

<Layout {...seo}>
  <main>
    <!-- Breadcrumb: slides down -->
    <section
      transition:animate={animDown}
      class="mx-auto max-w-4xl px-4 pt-8 sm:px-6"
    >
      <Breadcrumb
        items={[
          { label: "Home", href: "/" },
          { label: "Projects", href: "/projects" },
          { label: title, href: `/projects/${slug}` },
        ]}
      />
    </section>

    <!-- Header Section -->
    <section class="border-b border-border/40 bg-background px-4 py-12 sm:px-6">
      <div class="mx-auto max-w-4xl">
        <!-- Label: fades in from top -->
        <p
          transition:animate={animDown}
          class="mb-3 text-xs font-semibold uppercase tracking-[0.2em] text-muted-foreground"
        >
          Automation Workflow
        </p>

        <!-- Title: shared element morphs from card -->
        <h1
          transition:name={titleName}
          class="mb-4 text-3xl font-bold tracking-tight text-foreground sm:text-4xl lg:text-5xl"
        >
          {title}
        </h1>

        <!-- Description: fades up (delay 0) -->
        <div
          transition:animate={animUp0}
          class=" text-base leading-relaxed text-muted-foreground prose prose-sm"
          set:html={description}
        />

        <!-- Stack Badges: shared element morphs from card -->
        <div
          transition:name={stackName}
          class="mt-6 flex flex-wrap gap-2"
        >
          {stackTags.map((tag) => (
            <span class="inline-flex items-center rounded-md border border-border/50 bg-muted/60 px-2.5 py-0.5 text-xs font-medium text-muted-foreground">
              {tag}
            </span>
          ))}
        </div>
      </div>
    </section>

    <!-- Hero Preview: image or YouTube embed (delay 1) -->
    <section
      transition:animate={animUp1}
      class="mx-auto max-w-4xl px-4 py-12 sm:px-6"
    >
      <div class="overflow-hidden rounded-2xl border border-border/50 bg-card shadow-sm">
        {hasPreview ? (
          <>
            {isYouTube ? (
              <iframe
                src={getYouTubeEmbedUrl(previewUrl)}
                title={`${title} video`}
                class="h-64 w-full sm:h-80 md:h-96"
                frameborder="0"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
                allowfullscreen
              />
            ) : (
              <img
                transition:name={imgName}
                src={displayImageUrl}
                alt={`${title} workflow canvas`}
                class="h-full w-full object-cover"
                width="1200"
                height="675"
                onerror="this.style.display='none'; this.nextElementSibling.style.display='flex'"
              />
            )}
            <div style="display:none" class="h-64 flex-col items-center justify-center gap-3 text-center bg-muted/60">
              <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-muted-foreground/30">
                <rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/><circle cx="15" cy="15" r="1" fill="currentColor"/>
              </svg>
              <span class="text-sm text-muted-foreground/50">Workflow preview not available</span>
            </div>
          </>
        ) : (
          <div
            transition:name={imgName}
            class="flex h-64 flex-col items-center justify-center gap-3 text-center bg-muted/60"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-muted-foreground/30">
              <rect width="18" height="18" x="3" y="3" rx="2"/><path d="M3 9h18"/><path d="M9 21V9"/><circle cx="15" cy="15" r="1" fill="currentColor"/>
            </svg>
            <span class="text-sm text-muted-foreground/50">Workflow preview not available</span>
          </div>
        )}
      </div>
    </section>

    <!-- Navigation: fades up (delay 2) -->
    <section
      transition:animate={animUp2}
      class="mx-auto max-w-4xl px-4 pb-16 sm:px-6"
    >
      <DetailNavigation
        backLabel="All workflows"
        backHref="/projects"
        prevItem={prevProject ? { title: prevProject.title, slug: `/projects/${prevProject.slug}` } : undefined}
        nextItem={nextProject ? { title: nextProject.title, slug: `/projects/${nextProject.slug}` } : undefined}
      />
    </section>
  </main>
</Layout>
