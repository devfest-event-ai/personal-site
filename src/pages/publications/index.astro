---
import { desc, sql } from "drizzle-orm";
import { db } from "@/db";
import { publications } from "@/db/schema";
import Layout from "@/layouts/Layout.astro";

const result = await db
  .select({
    id: publications.id,
    title: publications.title,
    journal: publications.journal,
    publishedDate: publications.publishedDate,
    abstract: publications.abstract,
    doiUrl: publications.doiUrl,
    type: publications.type,
  })
  .from(publications)
  .orderBy(desc(publications.publishedDate));

function generateSlug(title: string): string {
  return title
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-|-$/g, "");
}

const allPubs = result.map((row) => ({
  id: Number(row.id),
  title: String(row.title),
  slug: generateSlug(String(row.title)),
  journal: String(row.journal),
  published_date: String(row.publishedDate),
  abstract: String(row.abstract),
  doi_url: row.doiUrl ? String(row.doiUrl) : null,
  type: String(row.type),
}));

const journals = allPubs.filter((p) => p.type === "journal");
const citations = allPubs.filter((p) => p.type === "citation");
---

<Layout
  title="Publications: Rachmawati Ari Taurisia"
  description="Academic publications and expert citations by Rachmawati Ari Taurisia covering AI curriculum design, digital transformation, and workflow automation research."
>
  <main>
    <!-- Page header: left-aligned, no glow, no pill badge -->
    <section class="border-b border-border/40 bg-background px-4 py-16 sm:px-6">
      <div class="mx-auto max-w-4xl">
        <div class="flex flex-col gap-8 lg:flex-row lg:items-end lg:justify-between">
          <div>
            <p class="animate-in fade-in duration-500 mb-3 text-xs font-semibold uppercase tracking-[0.2em] text-muted-foreground">
              Publications
            </p>
            <h1 class="animate-in fade-in slide-in-from-top-4 duration-700 mb-4 text-4xl font-bold tracking-tight text-foreground sm:text-5xl">
              Research &<br>
              <span class="text-primary">Expert Citations</span>
            </h1>
            <p class="animate-in fade-in duration-700 [animation-delay:200ms] max-w-lg text-base leading-relaxed text-muted-foreground">
              Academic contributions and industry citations on AI curriculum design,
              digital transformation, and automation.
            </p>
          </div>

          <!-- Stats: right side on desktop -->
          <div class="animate-in fade-in duration-700 [animation-delay:300ms] flex shrink-0 items-center gap-8 lg:flex-col lg:items-end lg:gap-3">
            <div class="lg:text-right">
              <p class="text-4xl font-bold tracking-tight text-foreground">{journals.length}</p>
              <p class="text-sm text-muted-foreground">journal papers</p>
            </div>
            <div class="h-8 w-px bg-border lg:hidden"></div>
            <div class="lg:text-right">
              <p class="text-4xl font-bold tracking-tight text-foreground">{citations.length}</p>
              <p class="text-sm text-muted-foreground">expert citations</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Journal Publications: editorial divide-y list -->
    {journals.length > 0 && (
      <section class="mx-auto max-w-4xl px-4 py-12 sm:px-6">
        <p class="mb-2 text-xs font-semibold uppercase tracking-[0.2em] text-muted-foreground">
          Peer-Reviewed Work
        </p>
        <div class="flex flex-col divide-y divide-border/50">
          {journals.map((pub, i) => {
            const dateObj = new Date(pub.published_date);
            const monthYear = dateObj.toLocaleDateString("id-ID", { year: "numeric", month: "short" });
            const fullDate  = dateObj.toLocaleDateString("id-ID", { year: "numeric", month: "long", day: "numeric" });

            return (
              <article
                data-animate
                style={`transition-delay: ${80 + i * 80}ms`}
                class="group py-8"
              >
                <a href={`/publications/${pub.slug}`} class="flex flex-col gap-3 sm:grid sm:grid-cols-[5rem_1fr] sm:gap-6">

                  <!-- Date column -->
                  <div class="hidden sm:flex sm:flex-col sm:items-end sm:pt-1">
                    <time datetime={pub.published_date} class="text-xs text-muted-foreground/60 leading-snug text-right">
                      {monthYear}
                    </time>
                  </div>

                  <!-- Content column -->
                  <div class="flex flex-col gap-3">
                    <div class="flex flex-wrap items-center gap-2">
                      <span class="inline-flex items-center rounded-md border border-primary/30 bg-primary/5 px-2 py-0.5 text-xs font-medium text-primary">
                        Journal Article
                      </span>
                      <time datetime={pub.published_date} class="text-xs text-muted-foreground/60 sm:hidden">
                        {fullDate}
                      </time>
                    </div>

                    <h2 class="text-xl font-bold tracking-tight text-foreground transition-colors group-hover:text-primary leading-snug">
                      {pub.title}
                    </h2>

                    <p class="text-xs font-medium text-muted-foreground">
                      {pub.journal}
                    </p>

                    <p class="text-sm leading-relaxed text-muted-foreground">
                      {pub.abstract}
                    </p>

                    <span class="mt-1 inline-flex w-fit items-center gap-1.5 text-sm font-semibold text-primary transition-all duration-200 hover:gap-2.5">
                      View details
                      <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
                      </svg>
                    </span>
                  </div>
                </a>
              </article>
            );
          })}
        </div>
      </section>
    )}

    <!-- Citations: separate section with decorative number -->
    {citations.length > 0 && (
      <section class="border-t border-border/40 bg-muted/20">
        <div class="mx-auto max-w-4xl px-4 py-12 sm:px-6">
          <div class="mb-8">
            <span
              data-animate="fade"
              class="mb-3 block font-mono text-6xl font-bold leading-none text-border"
              aria-hidden="true"
            >
              02
            </span>
            <h2
              data-animate
              class="text-2xl font-bold tracking-tight text-foreground sm:text-3xl"
            >
              Referenced as SME
            </h2>
            <p
              data-animate
              style="transition-delay: 100ms"
              class="mt-2 max-w-md text-base text-muted-foreground"
            >
              Cited as subject matter expert in academic and industry research.
            </p>
          </div>

          <div class="flex flex-col divide-y divide-border/50">
            {citations.map((pub, i) => {
              const dateObj = new Date(pub.published_date);
              const monthYear = dateObj.toLocaleDateString("id-ID", { year: "numeric", month: "short" });
              const fullDate  = dateObj.toLocaleDateString("id-ID", { year: "numeric", month: "long", day: "numeric" });

              return (
                <article
                  data-animate
                  style={`transition-delay: ${80 + i * 80}ms`}
                  class="group py-8"
                >
                  <a href={`/publications/${pub.slug}`} class="flex flex-col gap-3 sm:grid sm:grid-cols-[5rem_1fr] sm:gap-6">

                    <!-- Date column -->
                    <div class="hidden sm:flex sm:flex-col sm:items-end sm:pt-1">
                      <time datetime={pub.published_date} class="text-xs text-muted-foreground/60 leading-snug text-right">
                        {monthYear}
                      </time>
                    </div>

                    <!-- Content column -->
                    <div class="flex flex-col gap-3">
                      <div class="flex flex-wrap items-center gap-2">
                        <span class="inline-flex items-center rounded-md border border-amber-400/40 bg-amber-400/10 px-2 py-0.5 text-xs font-medium text-amber-400">
                          Citation
                        </span>
                        <time datetime={pub.published_date} class="text-xs text-muted-foreground/60 sm:hidden">
                          {fullDate}
                        </time>
                      </div>

                      <h2 class="text-lg font-bold tracking-tight text-foreground transition-colors group-hover:text-primary leading-snug">
                        {pub.title}
                      </h2>

                      <p class="text-xs font-medium text-muted-foreground">
                        {pub.journal}
                      </p>

                      <p class="text-sm leading-relaxed text-muted-foreground">
                        {pub.abstract}
                      </p>
                    </div>
                  </a>
                </article>
              );
            })}
          </div>
        </div>
      </section>
    )}

    {allPubs.length === 0 && (
      <p class="py-20 text-center text-muted-foreground">No publications found.</p>
    )}
  </main>
</Layout>
