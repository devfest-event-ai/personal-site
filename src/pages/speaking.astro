---
import Layout from "@/layouts/Layout.astro";
import { turso } from "@/lib/turso";

const result = await turso.execute("SELECT * FROM speaking ORDER BY id ASC");

const events = result.rows.map((row) => ({
  id:          Number(row.id),
  title:       String(row.title),
  provider:    String(row.provider),
  event_date:  String(row.event_date),
  role:        String(row.role),
  description: String(row.description),
  link:        String(row.link),
  modules:     (() => {
    try { return JSON.parse(String(row.modules)) as { title: string; desc: string }[]; }
    catch { return []; }
  })(),
}));

const courseSchema = events[0] ? {
  "@context": "https://schema.org",
  "@type": "Course",
  "name": events[0].title,
  "description": events[0].description,
  "provider": {
    "@type": "Organization",
    "name": events[0].provider,
  },
  "instructor": {
    "@type": "Person",
    "name": "Rachmawati Ari Taurisia",
  },
  "url": events[0].link,
} : null;
---

<Layout
  title="Speaking & Workshops — Rachmawati Ari Taurisia"
  description="Live workshop on productivity workflow automation: n8n, AI assistants, and real production blueprints. Participants leave with 2 working automations built from scratch."
>
  {courseSchema && (
    <script type="application/ld+json" set:html={JSON.stringify(courseSchema)} slot="head" />
  )}

  <main>
    <!-- Page header — left-aligned, no glow, no pill badge -->
    <section class="border-b border-border/40 bg-background px-4 py-16 sm:px-6">
      <div class="mx-auto max-w-4xl">
        <div class="flex flex-col gap-8 lg:flex-row lg:items-end lg:justify-between">
          <div>
            <p class="animate-in fade-in duration-500 mb-3 text-xs font-semibold uppercase tracking-[0.2em] text-muted-foreground">
              Speaking & Workshops
            </p>
            <h1 class="animate-in fade-in slide-in-from-top-4 duration-700 mb-4 text-4xl font-bold tracking-tight text-foreground sm:text-5xl">
              Live Training &amp;<br>
              <span class="text-primary">Workshop Sessions</span>
            </h1>
            <p class="animate-in fade-in duration-700 [animation-delay:200ms] max-w-lg text-base leading-relaxed text-muted-foreground">
              Deep-dive sessions where participants build real, production-ready automations —
              not just theory.
            </p>
          </div>

          <!-- Stats — right side on desktop -->
          <div class="animate-in fade-in duration-700 [animation-delay:300ms] flex shrink-0 items-center gap-8 lg:flex-col lg:items-end lg:gap-3">
            <div class="lg:text-right">
              <p class="text-4xl font-bold tracking-tight text-foreground">{events.length}</p>
              <p class="text-sm text-muted-foreground">workshop{events.length !== 1 ? "s" : ""}</p>
            </div>
            <div class="h-8 w-px bg-border lg:hidden"></div>
            <div class="lg:text-right">
              <p class="text-sm font-semibold text-foreground">2 automations</p>
              <p class="text-xs text-muted-foreground">built per session</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Speaking Events — editorial, no card box -->
    <section class="mx-auto max-w-4xl px-4 py-12 sm:px-6">
      {events.length > 0 ? (
        <div class="flex flex-col divide-y divide-border/50">
          {events.map((event, i) => {
            const dateObj = new Date(event.event_date);
            const monthYear  = dateObj.toLocaleDateString("id-ID", { year: "numeric", month: "short" });
            const fullDate   = dateObj.toLocaleDateString("id-ID", { year: "numeric", month: "long", day: "numeric" });

            return (
              <article
                data-animate
                style={`transition-delay: ${80 + i * 80}ms`}
                class="py-10"
              >
                <div class="flex flex-col gap-4 sm:grid sm:grid-cols-[5rem_1fr] sm:gap-6">

                  <!-- Date column -->
                  <div class="hidden sm:flex sm:flex-col sm:items-end sm:pt-1">
                    <time datetime={event.event_date} class="text-xs text-muted-foreground/60 leading-snug text-right">
                      {monthYear}
                    </time>
                  </div>

                  <!-- Content column -->
                  <div class="flex flex-col gap-4">
                    <div class="flex flex-wrap items-center gap-2">
                      <span class="inline-flex items-center rounded-md border border-primary/30 bg-primary/5 px-2 py-0.5 text-xs font-medium text-primary">
                        {event.provider}
                      </span>
                      <span class="inline-flex items-center rounded-md border border-border/50 bg-muted/60 px-2 py-0.5 text-xs font-medium text-muted-foreground">
                        {event.role}
                      </span>
                      <time datetime={event.event_date} class="text-xs text-muted-foreground/60 sm:hidden">
                        {fullDate}
                      </time>
                    </div>

                    <h2 class="text-xl font-bold tracking-tight text-foreground leading-snug sm:text-2xl">
                      {event.title}
                    </h2>

                    <p class="text-sm leading-relaxed text-muted-foreground">
                      {event.description}
                    </p>

                    <!-- Training modules -->
                    {event.modules.length > 0 && (
                      <div class="mt-2">
                        <p class="mb-4 text-xs font-semibold uppercase tracking-[0.2em] text-muted-foreground">
                          Training Modules
                        </p>
                        <ol class="space-y-4">
                          {event.modules.map((mod, j) => (
                            <li
                              data-animate
                              style={`transition-delay: ${200 + j * 80}ms`}
                              class="flex gap-4"
                            >
                              <span class="mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full bg-primary/10 text-xs font-bold text-primary">
                                {j + 1}
                              </span>
                              <div>
                                <p class="font-semibold text-foreground">{mod.title}</p>
                                <p class="mt-1 text-sm leading-relaxed text-muted-foreground">{mod.desc}</p>
                              </div>
                            </li>
                          ))}
                        </ol>
                      </div>
                    )}

                    <!-- CTA -->
                    <a
                      href={event.link}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="mt-2 inline-flex w-fit items-center gap-1.5 text-sm font-semibold text-primary transition-all duration-200 hover:gap-2.5"
                    >
                      Daftar Workshop
                      <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" x2="21" y1="14" y2="3"/>
                      </svg>
                    </a>
                  </div>
                </div>
              </article>
            );
          })}
        </div>
      ) : (
        <p class="py-20 text-center text-muted-foreground">No events found.</p>
      )}
    </section>
  </main>
</Layout>
