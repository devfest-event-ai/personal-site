---
export const prerender = false;

import type { TransitionDirectionalAnimations } from "astro";
import { desc, eq, gt, lt } from "drizzle-orm";
import ArticleContent from "@/components/ArticleContent.astro";
import Breadcrumb from "@/components/Breadcrumb.astro";
import DetailNavigation from "@/components/DetailNavigation.astro";
import { db } from "@/db";
import { writing } from "@/db/schema";
import Layout from "@/layouts/Layout.astro";

const { slug: paramSlug } = Astro.params;

if (!paramSlug) {
  return Astro.redirect("/404");
}

function generateSlug(title: string): string {
  return title
    .toLowerCase()
    .replace(/[^a-z0-9]+/g, "-")
    .replace(/^-|-$/g, "");
}

// Try to query by slug first using Drizzle
let articleRow: typeof writing.$inferSelect | null = null;
try {
  const result = await db
    .select()
    .from(writing)
    .where(eq(writing.slug, paramSlug))
    .limit(1);
  if (result.length > 0) {
    articleRow = result[0];
  }
} catch {
  // If slug column doesn't exist or query fails, fallback to fetching all and matching by title slug
  const allArticles = await db
    .select()
    .from(writing)
    .orderBy(desc(writing.publishedDate));

  articleRow =
    allArticles.find((a) => {
      const titleSlug = generateSlug(String(a.title));
      return titleSlug === paramSlug;
    }) || null;
}

if (!articleRow) {
  return Astro.redirect("/404");
}

const title = String(articleRow.title);
const articleSlug = articleRow.slug
  ? String(articleRow.slug)
  : generateSlug(title);
const category = String(articleRow.category);
const description = String(articleRow.description);
const url = String(articleRow.url);
const publishedDate = String(articleRow.publishedDate);
const content = articleRow.content ? String(articleRow.content) : null;
const coverImage = articleRow.coverImage ? String(articleRow.coverImage) : null;
const readingTime = articleRow.readingTime
  ? Number(articleRow.readingTime)
  : null;
const tagsStr = articleRow.tags ? String(articleRow.tags) : null;
const isExternal = articleRow.isExternal
  ? Number(articleRow.isExternal) === 1
  : false;

let tags: string[] = [];
if (tagsStr) {
  try {
    tags = JSON.parse(tagsStr);
  } catch {
    tags = [tagsStr];
  }
}

const dateObj = new Date(publishedDate);
const fullDate = dateObj.toLocaleDateString("id-ID", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const categoryColors: Record<string, string> = {
  Strategy: "border-blue-400/40 bg-blue-400/10 text-blue-400",
  "Technical Tutorial": "border-violet-400/40 bg-violet-400/10 text-violet-400",
  Analysis: "border-amber-400/40 bg-amber-400/10 text-amber-400",
};

const badgeClass =
  categoryColors[category] ??
  "border-border/50 bg-muted/60 text-muted-foreground";

// Get prev/next articles
let prevArticle: { title: string; slug: string } | null = null;
let nextArticle: { title: string; slug: string } | null = null;

try {
  const prevResult = await db
    .select({ id: writing.id, title: writing.title, slug: writing.slug, publishedDate: writing.publishedDate })
    .from(writing)
    .where(lt(writing.publishedDate, articleRow.publishedDate))
    .orderBy(desc(writing.publishedDate))
    .limit(1);

  if (prevResult.length > 0) {
    const row = prevResult[0];
    prevArticle = {
      title: String(row.title),
      slug: row.slug ? String(row.slug) : generateSlug(String(row.title)),
    };
  }
} catch {}

try {
  const nextResult = await db
    .select({ id: writing.id, title: writing.title, slug: writing.slug, publishedDate: writing.publishedDate })
    .from(writing)
    .where(gt(writing.publishedDate, articleRow.publishedDate))
    .orderBy(writing.publishedDate)
    .limit(1);

  if (nextResult.length > 0) {
    const row = nextResult[0];
    nextArticle = {
      title: String(row.title),
      slug: row.slug ? String(row.slug) : generateSlug(String(row.title)),
    };
  }
} catch {}

// Shared transition name — must match writing/index.astro
const titleName = `writing-title-${articleSlug}`;

const fadeBack = {
  old: { name: "vt-out", duration: "0.15s", easing: "ease-in",  fillMode: "both" },
  new: { name: "vt-in",  duration: "0.2s",  easing: "ease-out", fillMode: "both" },
};
const animDown: TransitionDirectionalAnimations = {
  forwards:  { old: { name: "vt-out",  duration: "0.15s", easing: "ease-in",  fillMode: "both" }, new: { name: "vt-down", duration: "0.35s", easing: "ease-out", fillMode: "both" } },
  backwards: fadeBack,
};
const animUp0: TransitionDirectionalAnimations = {
  forwards:  { old: { name: "vt-out", duration: "0.15s", easing: "ease-in",  fillMode: "both" }, new: { name: "vt-up", duration: "0.4s", easing: "ease-out", fillMode: "both" } },
  backwards: fadeBack,
};
const animUp1: TransitionDirectionalAnimations = {
  forwards:  { old: { name: "vt-out", duration: "0.15s", easing: "ease-in",  fillMode: "both" }, new: { name: "vt-up", duration: "0.4s", delay: "0.07s", easing: "ease-out", fillMode: "both" } },
  backwards: fadeBack,
};
const animUp2: TransitionDirectionalAnimations = {
  forwards:  { old: { name: "vt-out", duration: "0.15s", easing: "ease-in",  fillMode: "both" }, new: { name: "vt-up", duration: "0.4s", delay: "0.14s", easing: "ease-out", fillMode: "both" } },
  backwards: fadeBack,
};
const animUp3: TransitionDirectionalAnimations = {
  forwards:  { old: { name: "vt-out", duration: "0.15s", easing: "ease-in",  fillMode: "both" }, new: { name: "vt-up", duration: "0.4s", delay: "0.21s", easing: "ease-out", fillMode: "both" } },
  backwards: fadeBack,
};

const seo = {
  title: `${title} — Rachmawati Ari Taurisia`,
  description: description.substring(0, 160),
};
---

<Layout {...seo}>
  <main>
    <!-- Breadcrumb — slides down -->
    <section
      transition:animate={animDown}
      class="mx-auto max-w-4xl px-4 pt-8 sm:px-6"
    >
      <Breadcrumb
        items={[
          { label: "Home", href: "/" },
          { label: "Writing", href: "/writing" },
          { label: title, href: `/writing/${articleSlug}` },
        ]}
      />
    </section>

    <!-- Header Section -->
    <section class="border-b border-border/40 bg-background px-4 py-12 sm:px-6">
      <div class="mx-auto max-w-3xl">
        <div
          transition:animate={animDown}
          class="mb-4 flex flex-wrap items-center gap-3"
        >
          <span class={`inline-flex items-center rounded-md border px-2 py-0.5 text-xs font-medium ${badgeClass}`}>
            {category}
          </span>
          {isExternal && (
            <span class="inline-flex items-center rounded-md border border-border/50 bg-muted/60 px-2 py-0.5 text-xs font-medium text-muted-foreground">
              External Article
            </span>
          )}
        </div>

        <!-- Title — shared element morphs from list -->
        <h1
          transition:name={titleName}
          class="mb-4 text-3xl font-bold tracking-tight text-foreground sm:text-4xl lg:text-5xl"
        >
          {title}
        </h1>

        <div
          transition:animate={animUp0}
          class="flex flex-wrap items-center gap-4 text-sm text-muted-foreground"
        >
          <time datetime={publishedDate}>{fullDate}</time>
          {readingTime && (
            <>
              <span class="text-muted-foreground/40">·</span>
              <span>{readingTime} min read</span>
            </>
          )}
        </div>
      </div>
    </section>

    <!-- Cover Image — fades up (delay 1) -->
    {coverImage && (
      <section
        transition:animate={animUp1}
        class="mx-auto max-w-4xl px-4 py-8 sm:px-6"
      >
        <div class="overflow-hidden rounded-2xl border border-border/50 bg-card shadow-sm">
          <img
            src={coverImage}
            alt={title}
            class="h-full w-full object-cover"
            width="1200"
            height="630"
          />
        </div>
      </section>
    )}

    <!-- Article Content — fades up (delay 1 or 2) -->
    <section
      transition:animate={coverImage ? animUp2 : animUp1}
      class="mx-auto max-w-3xl px-4 py-8 sm:px-6"
    >
      {isExternal ? (
        <div class="rounded-2xl border border-border/50 bg-card p-8 shadow-sm">
          <p class="mb-6 text-base leading-relaxed text-muted-foreground">
            {description}
          </p>
          <a
            href={url}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-2 rounded-lg bg-primary px-6 py-3 text-sm font-semibold text-primary-foreground transition-all duration-200 hover:-translate-y-px hover:opacity-90 hover:shadow-md hover:shadow-primary/20"
          >
            Read full article on LinkedIn
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" x2="21" y1="14" y2="3"/>
            </svg>
          </a>
        </div>
      ) : content ? (
        <ArticleContent content={content} />
      ) : (
        <div class="rounded-2xl border border-border/50 bg-card p-8 shadow-sm">
          <p class="text-base leading-relaxed text-muted-foreground">
            {description}
          </p>
          {url && url !== "#" && (
            <a
              href={url}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-primary transition-all duration-200 hover:gap-2.5"
            >
              Read more
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" x2="21" y1="14" y2="3"/>
              </svg>
            </a>
          )}
        </div>
      )}
    </section>

    <!-- Tags — fades up (delay 2 or 3) -->
    {tags.length > 0 && (
      <section
        transition:animate={coverImage ? animUp3 : animUp2}
        class="mx-auto max-w-3xl px-4 pb-8 sm:px-6"
      >
        <div class="flex flex-wrap gap-2">
          {tags.map((tag) => (
            <span class="inline-flex items-center rounded-md border border-border/50 bg-muted/60 px-2.5 py-0.5 text-xs font-medium text-muted-foreground">
              {tag}
            </span>
          ))}
        </div>
      </section>
    )}

    <!-- Navigation — fades up (last) -->
    <section
      transition:animate={animUp3}
      class="mx-auto max-w-3xl px-4 pb-16 sm:px-6"
    >
      <DetailNavigation
        backLabel="All articles"
        backHref="/writing"
        prevItem={prevArticle ? { title: prevArticle.title, slug: `/writing/${prevArticle.slug}` } : undefined}
        nextItem={nextArticle ? { title: nextArticle.title, slug: `/writing/${nextArticle.slug}` } : undefined}
      />
    </section>
  </main>
</Layout>
