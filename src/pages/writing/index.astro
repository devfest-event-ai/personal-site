---
import Layout from "@/layouts/Layout.astro";
import { turso } from "@/lib/turso";

const result = await turso.execute("SELECT * FROM writing ORDER BY published_date DESC");

function generateSlug(title: string): string {
  return title.toLowerCase()
    .replace(/[^a-z0-9]+/g, '-')
    .replace(/^-|-$/g, '');
}

const articles = result.rows.map((row) => ({
  id:             Number(row.id),
  title:          String(row.title),
  slug:           row.slug ? String(row.slug) : generateSlug(String(row.title)),
  category:       String(row.category),
  description:    String(row.description),
  url:            String(row.url),
  published_date: String(row.published_date),
  is_external:    row.is_external ? Number(row.is_external) === 1 : false,
}));

const categoryColors: Record<string, string> = {
  "Strategy":           "border-blue-400/40 bg-blue-400/10 text-blue-400",
  "Technical Tutorial": "border-violet-400/40 bg-violet-400/10 text-violet-400",
  "Analysis":           "border-amber-400/40 bg-amber-400/10 text-amber-400",
};
---

<Layout
  title="Writing — Rachmawati Ari Taurisia"
  description="Articles on AI strategy, automation engineering, and curriculum design — written for productivity professionals and AI practitioners."
>
  <main>
    <!-- Page header — left-aligned, editorial, no glow, no pill badge -->
    <section class="border-b border-border/40 bg-background px-4 py-16 sm:px-6">
      <div class="mx-auto max-w-4xl">
        <p class="animate-in fade-in duration-500 mb-3 text-xs font-semibold uppercase tracking-[0.2em] text-muted-foreground">
          Writing
        </p>
        <h1 class="animate-in fade-in slide-in-from-top-4 duration-700 mb-4 text-4xl font-bold tracking-tight text-foreground sm:text-5xl">
          Ideas on AI &<br>Automation
        </h1>
        <p class="animate-in fade-in duration-700 [animation-delay:200ms] max-w-lg text-base leading-relaxed text-muted-foreground">
          Strategy, tutorials, and analysis for professionals building with AI —
          from curriculum design to production workflow automation.
        </p>
      </div>
    </section>

    <!-- Articles — editorial list, no card boxes -->
    <section class="mx-auto max-w-4xl px-4 py-12 sm:px-6">
      {articles.length > 0 ? (
        <div class="flex flex-col divide-y divide-border/50">
          {articles.map((article, i) => {
            const dateObj = new Date(article.published_date);
            const monthYear = dateObj.toLocaleDateString("id-ID", { year: "numeric", month: "short" });
            const fullDate  = dateObj.toLocaleDateString("id-ID", { year: "numeric", month: "long", day: "numeric" });
            const badgeClass = categoryColors[article.category] ?? "border-border/50 bg-muted/60 text-muted-foreground";
            const detailHref = article.is_external ? article.url : `/writing/${article.slug}`;
            const isExternalLink = article.is_external;

            return (
              <article
                data-animate
                style={`transition-delay: ${80 + i * 80}ms`}
                class="group py-8"
              >
                <a href={detailHref} target={isExternalLink ? "_blank" : undefined} rel={isExternalLink ? "noopener noreferrer" : undefined} class="flex flex-col gap-3 sm:grid sm:grid-cols-[5rem_1fr] sm:gap-6">

                  <!-- Date column -->
                  <div class="hidden sm:flex sm:flex-col sm:items-end sm:pt-1">
                    <time datetime={article.published_date} class="text-xs text-muted-foreground/60 leading-snug text-right">
                      {monthYear}
                    </time>
                  </div>

                  <!-- Content column -->
                  <div class="flex flex-col gap-3">
                    <div class="flex flex-wrap items-center gap-2">
                      <span class={`inline-flex items-center rounded-md border px-2 py-0.5 text-xs font-medium ${badgeClass}`}>
                        {article.category}
                      </span>
                      {isExternalLink && (
                        <span class="inline-flex items-center rounded-md border border-border/50 bg-muted/60 px-2 py-0.5 text-xs font-medium text-muted-foreground">
                          External
                        </span>
                      )}
                      <!-- Date on mobile -->
                      <time datetime={article.published_date} class="text-xs text-muted-foreground/60 sm:hidden">
                        {fullDate}
                      </time>
                    </div>

                    <h2 class="text-xl font-bold tracking-tight text-foreground transition-colors group-hover:text-primary leading-snug">
                      {article.title}
                    </h2>

                    <p class="text-sm leading-relaxed text-muted-foreground">
                      {article.description}
                    </p>

                    <span class="mt-1 inline-flex w-fit items-center gap-1.5 text-sm font-semibold text-primary transition-all duration-200 hover:gap-2.5">
                      {isExternalLink ? "Read on LinkedIn" : "Read article"}
                      <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        {isExternalLink ? (
                          <>
                            <path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" x2="21" y1="14" y2="3"/>
                          </>
                        ) : (
                          <>
                            <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
                          </>
                        )}
                      </svg>
                    </span>
                  </div>
                </a>
              </article>
            );
          })}
        </div>
      ) : (
        <p class="py-20 text-center text-muted-foreground">No articles found.</p>
      )}
    </section>
  </main>
</Layout>
